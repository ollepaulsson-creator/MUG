{%- doc -%}
  Renders the product's vendor as a link to its brand page (the real brand
  collection when one exists, else the automatic vendor page). Renders
  through the 'text' snippet so all text-block settings (type preset,
  color, padding) behave exactly like the plain text block it replaces.
{%- enddoc -%}

{% if closest.product != blank %}
  {%- capture brand_url -%}{% render 'vendor-collection-url', vendor: closest.product.vendor %}{%- endcapture -%}
  {%- capture vendor_html -%}
    <p><a class="vendor-link" href="{{ brand_url | strip }}">{{ closest.product.vendor | escape }}</a></p>
  {%- endcapture -%}
  {% render 'text', fallback_text: vendor_html, block: block %}
{% endif %}

