{% comment %}
  robots.txt.liquid — Shopify robots template
  Outputs Shopify's defaults then blocks filter/sort parameter URLs
  that create duplicate collection content.
{% endcomment %}

{% for group in robots.default_groups %}
{{ group.user_agent }}
{% for rule in group.rules -%}
{%- comment -%}
  Shopify's default "*/collections/*filter*&*filter*" starts with "*" —
  formally invalid robots syntax (paths must start with "/"), flagged by
  validators. Emit a "/"-prefixed equivalent pair instead.
{%- endcomment -%}
{%- assign rule_value = rule.value -%}
{%- if rule_value == '*/collections/*filter*&*filter*' -%}
{{ rule.directive }}: /collections/*filter*&*filter*
{{ rule.directive }}: /*/collections/*filter*&*filter*
{% else -%}
{{ rule.directive }}: {{ rule_value }}
{% endif -%}
{% endfor %}
{%- if group.user_agent.value == '*' -%}
# Extra: block sort/filter parameter URLs (duplicate content).
# pf_* are legacy Boost-filter params still linked from old content.
# Deliberately NOT blocking ?page= — pagination must stay crawlable.
Disallow: /*?sort_by=
Disallow: /*?filter.
Disallow: /*?pf_*
Disallow: /*&pf_*
{% endif %}
{% if group.sitemap -%}
Sitemap: {{ group.sitemap.value }}
{% endif %}

{% endfor %}
