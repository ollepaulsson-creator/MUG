{% comment %}
  robots.txt.liquid — Shopify robots template
  Outputs Shopify's defaults then blocks filter/sort parameter URLs
  that create duplicate collection content.
{% endcomment %}

{% for group in robots.default_groups %}
{{ group.user_agent }}
{% for rule in group.rules -%}
{{ rule.directive }}: {{ rule.value }}
{% endfor %}
{%- if group.user_agent.value == '*' -%}
# Extra: block sort/filter parameter URLs (duplicate content).
# pf_* are legacy Boost-filter params still linked from old content.
# Deliberately NOT blocking ?page= — pagination must stay crawlable.
Disallow: /*?sort_by=
Disallow: /*?filter.
Disallow: /*?pf_*
Disallow: /*&pf_*
{% endif %}
{% if group.sitemap -%}
Sitemap: {{ group.sitemap.value }}
{% endif %}

{% endfor %}
