    "custom_liquid_KrgeXX": {
      "type": "custom-liquid",
      "disabled": true,
      "custom_css": [
        ".product-card img {width: 100%; aspect-ratio: 1 / 1; /* ✅ square image box */ object-fit: contain; /* or cover if you want cropping */ border-bottom: 0px solid #ddd; padding: 0px;}"
      ],
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "{% paginate collection.products by 8 %}\n\n  <!-- 🔹 Filtering + Sorting Bar -->\n  <div class=\"filter-sort-bar\">\n    <!-- Left: Filter -->\n    <div class=\"filter-box\">\n      <form method=\"get\" action=\"\">\n        <label for=\"filter\">Filter:</label>\n        <select id=\"filter\" name=\"filter\" onchange=\"this.form.submit()\">\n          <option value=\"\">All Products</option>\n          {% for tag in collection.all_tags %}\n            <option value=\"{{ tag | handleize }}\" {% if current_tags contains tag %}selected{% endif %}>\n              {{ tag }}\n            </option>\n          {% endfor %}\n        </select>\n      </form>\n    </div>\n\n    <!-- Right: Sort -->\n    <div class=\"sort-box\">\n      <form method=\"get\" action=\"\">\n        <label for=\"sort-by\">Sort by:</label>\n        <select id=\"sort-by\" name=\"sort_by\" onchange=\"this.form.submit()\">\n          <option value=\"manual\" {% if collection.sort_by == \"manual\" %}selected{% endif %}>Featured</option>\n          <option value=\"best-selling\" {% if collection.sort_by == \"best-selling\" %}selected{% endif %}>Best Selling</option>\n          <option value=\"title-ascending\" {% if collection.sort_by == \"title-ascending\" %}selected{% endif %}>Alphabetically, A–Z</option>\n          <option value=\"title-descending\" {% if collection.sort_by == \"title-descending\" %}selected{% endif %}>Alphabetically, Z–A</option>\n          <option value=\"price-ascending\" {% if collection.sort_by == \"price-ascending\" %}selected{% endif %}>Price, Low to High</option>\n          <option value=\"price-descending\" {% if collection.sort_by == \"price-descending\" %}selected{% endif %}>Price, High to Low</option>\n          <option value=\"created-descending\" {% if collection.sort_by == \"created-descending\" %}selected{% endif %}>Newest</option>\n          <option value=\"created-ascending\" {% if collection.sort_by == \"created-ascending\" %}selected{% endif %}>Oldest</option>\n        </select>\n      </form>\n    </div>\n  </div>\n\n  <!-- 🔹 Product Grid -->\n  <div class=\"product-grid\">\n    {% for product in collection.products %}\n      <div class=\"product-card\">\n        <div class=\"product-image\">\n          {% if product.compare_at_price > product.price %}\n            <span class=\"sale-badge\">SALE</span>\n          {% endif %}\n          <a href=\"{{ product.url }}\">\n            {{ product.featured_image | image_url: width: 400 | image_tag }}\n          </a>\n        </div>\n        <h3 class=\"product-title\"><a href=\"{{ product.url }}\">{{ product.title }}</a></h3>\n        <p class=\"product-price\">\n          {% if product.compare_at_price > product.price %}\n            <span class=\"old-price\">{{ product.compare_at_price | money }}</span>\n          {% endif %}\n          <span class=\"current-price\">{{ product.price | money }}</span>\n        </p>\n      </div>\n    {% endfor %}\n  </div>\n\n  <!-- 🔹 Pagination -->\n  <div class=\"custom-pagination\">\n    {% if paginate.pages > 1 %}\n      <ul>\n        {% if paginate.previous %}\n          <li><a href=\"{{ paginate.previous.url }}\">&laquo; Prev</a></li>\n        {% endif %}\n        {% for part in paginate.parts %}\n          {% if part.is_link %}\n            <li><a href=\"{{ part.url }}\">{{ part.title }}</a></li>\n          {% else %}\n            <li class=\"active\">{{ part.title }}</li>\n          {% endif %}\n        {% endfor %}\n        {% if paginate.next %}\n          <li><a href=\"{{ paginate.next.url }}\">Next &raquo;</a></li>\n        {% endif %}\n      </ul>\n    {% endif %}\n  </div>\n\n{% endpaginate %}",
        "color_scheme": "",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0,
        "enable_custom_css_liquid": true,
        "custom_css_liquid": "<div class=\"product-card\">\n  <span class=\"sale-badge\">SALE</span>\n  <img src=\"product-image.jpg\" alt=\"Product\">\n  <h3 class=\"product-title\">Product Name</h3>\n  <p class=\"product-price\">\n    <span class=\"old-price\">$100</span>\n    <span class=\"current-price\">$50</span>\n  </p>\n</div>\n\n\n\n\n.product-grid {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr); /* 4 per row */\n  gap: 0px;\n  margin: 0px auto;\n  max-width: 1200px; /* optional */\n}\n\n.product-card {\n  border: 1px solid #ddd;\n  text-align: left;\n  background: #fff;\n  position: relative; /* ✅ makes absolute children align inside */\n  overflow: hidden;   /* keeps badge inside */\n}\n\n.sale-badge {\n  position: absolute;\n  top: 10px;     /* distance from top */\n  left: 10px;    /* distance from left */\n  background: white;\n  color: dark-gray;\n  font-size: 12px;\n  font-weight: bold;\n  padding: 5px 8px;\n  border-radius: 4px;\n  text-transform: uppercase;\n  z-index: 2;    /* sits above image */\n}\n\n\n.product-card img {\n\n  padding: 15px;\n border-bottom: 1px solid #ddd;\n  width: 100%;\n  height: auto;\n}\n\n.product-title {\n  padding-left: 15px;\n  font-size: 16px;\n font-weight: 400;\n  margin: 10px 0 5px;\n}\n\n.product-price {\n  padding-left: 15px;\n   padding-bottom: 15px;\n  font-weight: bold;\n}\n\n/* Pagination */\n.custom-pagination {\n  text-align: center;\n  margin-top: 30px;\n}\n.custom-pagination ul {\n  list-style: none;\n  display: inline-flex;\n  gap: 8px;\n  padding: 0;\n}\n.custom-pagination li {\n  border: 1px solid #ddd;\n  padding: 6px 12px;\n  border-radius: 4px;\n}\n.custom-pagination li.active {\n  background: #000;\n  color: #fff;\n}\n.custom-pagination a {\n  text-decoration: none;\n  color: #000;\n}\n.custom-pagination a:hover {\n  background: #000;\n  color: #fff;\n}\n\n.filter-sort-bar {\n  display: flex;\n  justify-content: space-between; /* pushes filter left, sort right */\n  align-items: center;\n  margin: 20px 0; /* no auto-centering */\n  width: 100%;    /* make it span full width */\n  max-width: 1200px; /* optional, only if you want to limit */\n}\n\n\n/* Filter + Sort boxes */\n.filter-box,\n.sort-box {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n}\n.old-price {\ntext-decoration: line-through; \ncolor: #000; /* keep current price black */\n  font-weight: bold;\n}\n\n.current-price {\n  color: red;\n  /* adds the strikethrough effect */\n  margin-right: 5px;             /* space before current price */\n  \n}\n\n/* Labels */\n.filter-sort-bar label {\n  font-weight: bold;\n}\n\n/* Dropdowns */\n.filter-sort-bar select {\n  padding: 6px 10px; /* ✅ Removed padding-left: 80px */\n  border: 1px solid #ddd;\n  border-radius: 4px;\n  background: #fff;\n}\n\n\n/* ✅ Responsive for tablets & mobile (<= 768px) */\n@media (max-width: 768px) {\n  /* Product grid: 2 per row */\n  .product-grid {\n    grid-template-columns: repeat(2, 1fr);\n  }\n\n  /* Filter + Sort stay inline */\n  .filter-sort-bar {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    gap: 10px;\n    margin: 10px 0;\n    flex-wrap: nowrap;   /* ✅ keep inline, no stacking */\n  }\n\n  .filter-box,\n  .sort-box {\n    flex: 1 1 45%;       /* take half each */\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n\n  .filter-sort-bar select {\n    flex: 1;\n    width:20px;             /* dropdown stretches inside */\n    min-width: 120px;\n  }\n\n  /* Pagination fits screen */\n  .custom-pagination ul {\n    display: flex;\n    flex-wrap: wrap;       /* ✅ wrap instead of overflow */\n    justify-content: center;\n    gap: 6px;\n    max-width: 100%;       /* ✅ stays inside screen */\n  }\n\n  .custom-pagination li {\n    padding: 4px 8px;\n    font-size: 10px;\n    flex-shrink: 0;        /* prevent squishing */\n  }\n}\n\n\n/* ✅ Fullscreen desktop (>= 1440px) */\n@media (min-width: 769px) {\n  .product-grid {\n    grid-template-columns: repeat(4, 1fr); /* stay 4 per row */\n    width: 100%;\n    max-width: 100%;\n  }\n\n  .filter-sort-bar {\n   padding-left:15px;\n   padding-right:15px;\n    width: 100%;\nmax-width: none;\n    justify-content: space-between; /* filter far left, sort far right */\n  }\n\n  .sort-box {\n    margin-left: auto; /* push sort to right edge */\n  }\n}"
      }
