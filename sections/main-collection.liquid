{% assign product_shown = section.settings.product_shown %}

{% comment %} ── Featured grid section: read from collection metafield custom.featured_grid ── {% endcomment %}
{% assign featured_keys = collection.metafields.custom.featured_grid.value | split: ',' | compact %}
{% assign featured_key = nil %}
{% if featured_keys.size > 0 %}
  {% assign rand = 'now' | date: '%S' | plus: 0 | modulo: featured_keys.size %}
  {% assign featured_key_raw = featured_keys[rand] %}
  {% assign featured_key = featured_key_raw | strip | downcase | replace: 'å', 'a' | replace: 'ä', 'a' | replace: 'ö', 'o' | replace: ' ', '-' %}
{% endif %}

<script>
  (function() {
    var url = new URL(window.location.href);
    if (!url.searchParams.has('filter.v.availability')) {
      url.searchParams.set('filter.v.availability', '1');
      window.location.replace(url.toString());
    }
  })();
</script>

{% unless section.settings.enable_pagination %}
<script
  src="{{ 'results-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>
{% endunless %}

<script>
  // product-card.js appends `#<section-id>-<product-id>` to the collection
  // URL when a card is clicked, so returning to the collection lands on a
  // URL with a hash. Both the browser's native anchor scroll and any
  // scrollIntoView would align that card to the top of the viewport,
  // hiding the sticky header. Strip the hash before the grid is parsed
  // so no scroll-to-anchor ever happens — the page loads at the top.
  (function() {
    if (window.location.hash) {
      const cleanUrl = window.location.pathname + window.location.search;
      history.replaceState(history.state, '', cleanUrl);
    }
  })();
</script>


{% comment %} We always render this full-width, as the child blocks have width: page/full settings {% endcomment %}
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<results-list
  class="section product-grid-container color-{{ section.settings.color_scheme }}"
  style="--padding-block-start: {{ section.settings.padding-block-start }}px; --padding-block-end: {{ section.settings.padding-block-end }}px;"
  section-id="{{ section.id }}"
>
  {% render 'skip-to-content-link', href: '#ResultsList', text: 'accessibility.skip_to_results_list' %}

  <div
    class="collection-wrapper grid gap-style{% if collection.products_count == 0 %} collection-wrapper--no-results{% endif %}"
  >
    {% content_for 'block',
      type: 'filters',
      id: 'filters',
      results: collection,
      results_size: collection.products_count
    %}

    {% paginate collection.products by product_shown %}
      {%- assign show_featured_slot = false -%}
      {%- if featured_key and paginate.current_page == 1 -%}
        {%- assign show_featured_slot = true -%}
      {%- endif -%}
      {% capture children %}
        {% for product in collection.products %}
          {%- comment -%}
            ── Featured slot placeholder ──
            Rendered in Liquid at source position 3 so the grid slot
            (grid-column: span 2 / -1; grid-row: 1 / span 2 at ≥1024px)
            is reserved from first paint. The script below moves the
            pre-rendered Instant section into this placeholder, so no
            layout shift occurs when content arrives.
          {%- endcomment -%}
          {%- if show_featured_slot and forloop.index == 3 -%}
            <li id="featured-grid-slot-{{ section.id }}" class="product-grid__item product-grid__item--featured" data-featured-slot data-skip-subtree-update></li>
          {%- endif -%}
          <li
            id="{{ section.id }}-{{ product.id }}"
            class="product-grid__item product-grid__item--{{ forloop.index0 }}"
            data-page="{{ paginate.current_page }}"
            data-product-id="{{ product.id }}"
            ref="cards[]"
            style="--card-index: {{ forloop.index0 | at_most: 8 }}"
          >
            {% # theme-check-disable %}
            {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
            {% # theme-check-enable %}
          </li>
        {% endfor %}
      {% endcapture %}

      {% render 'product-grid',
        section: section,
        children: children,
        products: collection.products,
        paginate: paginate
      %}

      {% comment %} ── Featured section: JS fills pre-rendered placeholder ── {% endcomment %}
      {% style %}
        [id*="__featured_"] { display: none !important; }
      {% endstyle %}
      {% if show_featured_slot %}
        <script>
        (function() {
          function injectFeatured() {
            if (window.innerWidth < 1024) return;
            var featuredKey = '{{ featured_key }}';
            var sectionKey = 'featured_' + featuredKey.replace(/-/g, '_');
            var sectionEl = document.querySelector('[id$="__' + sectionKey + '"]');
            if (!sectionEl) return;
            var grid = document.querySelector('.product-grid--{{ section.id }}');
            if (!grid) return;
            var placeholder = grid.querySelector(':scope > [data-featured-slot]');
            if (!placeholder || placeholder.firstElementChild) return;
            sectionEl.style.setProperty('display', 'block', 'important');
            placeholder.appendChild(sectionEl);
          }
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', injectFeatured);
          } else {
            injectFeatured();
          }
        })();
        </script>
      {% endif %}

      {% if section.settings.enable_pagination %}
        {%- comment -%} Pagination controls {%- endcomment -%}
        {% if paginate.pages > 1 %}
          <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
            <ul class="pagination__list" role="list">

              {%- if paginate.previous -%}
                <li class="pagination__item pagination__item--prev">
                  <a href="{{ paginate.previous.url | escape }}#ResultsList"
                    rel="prev"
                    aria-label="{{ 'general.pagination.previous' | t }}">
                    <span class="pagination__arrow">◄</span> Föregående
                  </a>
                </li>
              {%- endif -%}

              {%- assign prev_page_num = paginate.current_page | minus: 1 -%}
              {%- assign next_page_num = paginate.current_page | plus: 1 -%}
              {%- for part in paginate.parts -%}
                {%- assign item_class = 'pagination__item' -%}
                {%- if part.is_link -%}
                  {%- if part.title == prev_page_num -%}
                    {%- assign item_class = item_class | append: ' pagination__item--prev-page' -%}
                  {%- endif -%}
                  {%- if part.title == next_page_num -%}
                    {%- assign item_class = item_class | append: ' pagination__item--next-page' -%}
                  {%- endif -%}
                  {%- if part.title == paginate.pages -%}
                    {%- assign item_class = item_class | append: ' pagination__item--last-page' -%}
                  {%- endif -%}
                  <li class="{{ item_class }}">
                    <a href="{{ part.url | escape }}#ResultsList"
                      aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                      {{ part.title }}
                    </a>
                  </li>
                {%- elsif part.title == paginate.current_page -%}
                  <li class="{{ item_class }} pagination__item--current" aria-current="page">
                    {{ part.title }}
                  </li>
                {%- else -%}
                  <li class="{{ item_class }} pagination__item--ellipsis">
                    <span class="pagination__ellipsis">{{ part.title }}</span>
                  </li>
                {%- endif -%}
              {%- endfor -%}

              {%- if paginate.next -%}
                <li class="pagination__item pagination__item--next">
                  <a href="{{ paginate.next.url | escape }}#ResultsList"
                    rel="next"
                    aria-label="{{ 'general.pagination.next' | t }}">
                    Nästa <span class="pagination__arrow">►</span>
                  </a>
                </li>
              {%- endif -%}

            </ul>
          </nav>
        {% endif %}
      {% endif %}

    {% endpaginate %}

  </div>
</results-list>


{% style %}

  {% if section.settings.enable_pagination %}
    .collection-wrapper.grid.gap-style {
        display: flex;
        flex-direction: column;
    }
    .pagination__ellipsis {
      color: #000000;
    }
    .pagination { margin-top: var(--spacing-6, 36px); text-align: center; }
    .pagination__list { display: inline-flex; gap: 8px; align-items: center;list-style: none; }
    .pagination__item { padding: 2px; border-radius: 0px; }
    .pagination__item a { text-decoration: none; }
    .pagination__item--current { font-weight: 600; outline: 1px solid var(--color-border, #ddd); }
    .pagination__item--prev a, .pagination__item--next a { font-weight: 500; outline: none}

    @media (max-width: 749px) {
      /* Hide text nav buttons on mobile — numbers only */
      .pagination__item--prev,
      .pagination__item--next {
        display: none;
      }
      /* Show 4 page numbers: prev | current | next | last */
      .pagination__item:not(.pagination__item--prev-page):not(.pagination__item--current):not(.pagination__item--next-page):not(.pagination__item--last-page) {
        display: none;
      }
    }
  {% endif %}

{% endstyle %}

{%- if section.settings.enable_custom_css_liquid -%}
  {% style %}
  #shopify-section-{{ section.id }} {
    {{ section.settings.custom_css_liquid }} 
  }
  {% endstyle %}
{%- endif -%}


{% schema %}
{
  "name": "t:names.collection_container",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Custom CSS Liquid"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_css_liquid",
      "label": "Enable Custom CSS Liquid",
      "default": false
    },
    {
      "type": "liquid",
      "id": "custom_css_liquid",
      "label": "Custom CSS Liquid"
    },
    {
      "type": "range",
      "id": "product_shown",
      "label": "Product Shown",
      "min": 6,
      "max": 50,
      "step": 1,
      "default": 8
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:settings.type",
      "options": [
        {
          "value": "grid",
          "label": "t:options.grid"
        },
        {
          "value": "organic",
          "label": "t:options.editorial"
        }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "product_card_size",
      "label": "t:settings.card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "medium",
          "label": "t:options.medium"
        },
        {
          "value": "large",
          "label": "t:options.large"
        },
        {
          "value": "extra-large",
          "label": "t:options.extra_large"
        }
      ],
      "default": "medium",
      "visible_if": "{{ section.settings.layout_type == 'grid' }}"
    },
    {
      "type": "select",
      "id": "mobile_product_card_size",
      "label": "t:settings.mobile_card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "large",
          "label": "t:options.large"
        }
      ],
      "default": "small"
    },
    {
      "type": "checkbox",
      "id": "enable_pagination",
      "label": "Enable Pagination",
      "default": false
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "product_grid_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "centered",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "centered"
    },
    {
      "type": "checkbox",
      "id": "full_width_on_mobile",
      "label": "t:settings.full_width_on_mobile",
      "default": true,
      "visible_if": "{{ section.settings.product_grid_width != 'full-width' }}"
    },
    {
      "type": "range",
      "id": "columns_gap_horizontal",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "columns_gap_vertical",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
      },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": []
}
{% endschema %}
