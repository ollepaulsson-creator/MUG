<script
  src="{{ 'product-recommendations.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% liquid
  case section.settings.layout_type
    when 'grid'
      assign classes = 'resource-list--grid'
    when 'carousel'
      assign classes = 'resource-list__carousel'
  endcase

  capture styles
    echo '--column-count-mobile: ' | append: section.settings.mobile_columns | append: ';'
    echo '--resource-list-column-gap-desktop: ' | append: section.settings.columns_gap | append: 'px;'
    echo '--resource-list-row-gap-desktop: ' | append: section.settings.rows_gap | append: 'px;'
    echo '--resource-list-columns: repeat(' | append: section.settings.columns | append: ', 1fr);'
    echo '--resource-list-columns-mobile: repeat(' | append: section.settings.mobile_columns | append: ', 1fr);'
    echo '--resource-list-column-gap-desktop: ' | append: section.settings.columns_gap | append: 'px;'
    echo '--column-count: ' | append: section.settings.columns | append: ';'
    echo '--column-count-mobile: ' | append: section.settings.mobile_columns | append: ';'
  endcapture

  # Determine if we have a real product context to render from (initial page load)
  assign source_product = section.settings.product | default: product
  if source_product != blank
    assign has_product_context = true
  else
    assign has_product_context = false
  endif
%}

<product-recommendations
  id="product-recommendations-{{ section.id }}"
  class="product-recommendations"
  data-url="{{ routes.product_recommendations_url }}?limit=10"
  data-section-id="{{ section.id }}"
  data-product-id="{{ section.settings.product.id | default: product.id }}"
  data-intent="{{ section.settings.recommendation_type }}"
  data-testid="product-recommendations-section"
  data-recommendations-performed="{{ recommendations.performed }}"
  {{ section.shopify_attributes }}
>
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div
    class="
      section
      section--{{ section.settings.section_width }}
      color-{{ section.settings.color_scheme }}
      section-resource-list
      spacing-style
      gap-style
    "
    style="
      {%  render 'spacing-style', settings: section.settings %}
      {%  render 'gap-style', value: section.settings.gap %}
      {{ styles }}
    "
  >
    <div class="section-resource-list__content">
      {% content_for 'blocks' %}
    </div>

    {% if recommendations.performed or has_product_context or section.settings.product == blank %}
      {% liquid
  assign max_display = section.settings.max_products
  if max_display > 24
    assign max_display = 24
  endif

  assign current_product = section.settings.product | default: product

  if current_product != blank
    assign type_products = blank

    if recommendations.performed
      # --- Search & Discovery path ---
      # Trust Shopify's algorithm fully — use all 10, only filter unavailable/current product
      assign rec_filtered = recommendations.products | where: 'available', true | reject: 'id', current_product.id

      # Uprank same vendor within recommendations
      assign same_vendor = rec_filtered | where: 'vendor', current_product.vendor
      assign other_vendors = rec_filtered | reject: 'vendor', current_product.vendor
      assign type_products = same_vendor | concat: other_vendors

      # Fill gaps using the best collection if recommendations don't have enough
      if type_products.size < max_display
        assign best_collection = blank
        assign best_type_count = 0
        for col in current_product.collections
          unless col.handle == 'all'
            assign col_type_count = col.products | where: 'type', current_product.type | where: 'available', true | size
            if col_type_count > best_type_count
              assign best_collection = col
              assign best_type_count = col_type_count
            endif
          endunless
        endfor
        if best_collection != blank
          assign fill = best_collection.products | where: 'type', current_product.type | where: 'available', true | reject: 'id', current_product.id
          for existing in type_products
            assign fill = fill | reject: 'id', existing.id
          endfor
          assign fill_same_vendor = fill | where: 'vendor', current_product.vendor
          assign fill_other_vendors = fill | reject: 'vendor', current_product.vendor
          assign fill_sorted = fill_same_vendor | concat: fill_other_vendors
          assign type_products = type_products | concat: fill_sorted
        endif
      endif

    else
      # --- Initial server-side render path (before AJAX fires) ---
      assign best_collection = blank
      assign best_type_count = 0
      for col in current_product.collections
        unless col.handle == 'all'
          assign col_type_count = col.products | where: 'type', current_product.type | where: 'available', true | size
          if col_type_count > best_type_count
            assign best_collection = col
            assign best_type_count = col_type_count
          endif
        endunless
      endfor
      if best_collection != blank
        assign type_products = best_collection.products | where: 'type', current_product.type | where: 'available', true | reject: 'id', current_product.id
      else
        assign type_products = collections.all.products | where: 'type', current_product.type | where: 'available', true | reject: 'id', current_product.id
      endif
      assign same_vendor = type_products | where: 'vendor', current_product.vendor
      assign other_vendors = type_products | reject: 'vendor', current_product.vendor
      assign type_products = same_vendor | concat: other_vendors
    endif

    assign products = type_products | slice: 0, max_display

  else
    # Theme editor placeholder
    assign products = null
    for i in (1..max_display)
      assign products = products | append: ', '
      assign products = products | split: ','
    endfor
  endif
%}


{% capture list_items %}
        {% for product in products limit: 24 %}
          <div class="resource-list__item">
            {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: product %}
          </div>
          {% unless forloop.last %}<!--@list/split-->{% endunless %}
        {% endfor %}
      {% endcapture %}

      {% liquid
        assign slide_content = list_items | strip
        assign slides = slide_content | split: '<!--@list/split-->'
        if products != blank and products.size > 0
          assign has_recommendations = 'true'
        else
          assign has_recommendations = 'false'
        endif
      %}

      <div
        class="
          resource-list
          {% if section.settings.layout_type == 'carousel' %}force-full-width{% endif %}
          {% if section.settings.carousel_on_mobile and section.settings.layout_type != 'carousel' %}hidden--mobile{% endif %}
          {{ classes }}"
        data-has-recommendations="{{ has_recommendations }}"
        {% if section.settings.layout_type == 'grid' %}data-testid="resource-list-grid"{% endif %}
      >
        {% case section.settings.layout_type %}
          {% when 'grid' %}
            {{ list_items }}
          {% when 'carousel' %}
            {% render 'resource-list-carousel',
              ref: 'resourceListCarousel',
              slides: slides,
              slide_count: recommendations.products.size,
              settings: section.settings
            %}
        {% endcase %}
      </div>

      <!-- Show More Button -->
      <div class="show-more-wrapper" style="text-align:center; margin-top: 20px; justify-content: center; display: flex;">
        <button id="show-more-products" class="button">VISA FLER</button>
      </div>

    {% else %}
      <div class="resource-list resource-list--grid">
        {% for i in (1..section.settings.columns) %}
          <div class="product-recommendations__skeleton-item" aria-label="{{ 'accessibility.loading_product_recommendations' | t }}"></div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</product-recommendations>

{% stylesheet %}
  .product-recommendations__skeleton-item {
    aspect-ratio: 3 / 4;
    background-color: var(--color-foreground);
    opacity: var(--skeleton-opacity);
    border-radius: 4px;
  }

  @media screen and (max-width: 749px) {
    .product-recommendations__skeleton-item:nth-child(2n + 1) {
      display: none;
    }
  }

  product-recommendations:has([data-has-recommendations='false']) {
    display: none;
  }
{% endstylesheet %}

<script>
function setupShowMore() {
  const productSection = document.querySelector('product-recommendations');
  if (!productSection) return false;

  const grid = productSection.querySelector('.resource-list--grid');
  const showMoreBtn = productSection.querySelector('#show-more-products');

  if (!grid || !showMoreBtn) return false;

  // Already set up for this content — skip to avoid duplicate listeners
  if (showMoreBtn.dataset.showMoreSetup === 'true') return true;

  const items = Array.from(grid.querySelectorAll('.resource-list__item'));
  if (!items.length) return false;

  const batchSize = 8;
  let visible = batchSize;

  // Hide items after the first batch
  items.forEach((item, index) => {
    if (index >= visible) item.style.display = 'none';
  });

  // Hide button if all items already visible
  if (items.length <= visible) showMoreBtn.style.display = 'none';

  // Button click: reveal next batch, hide button when all shown
  showMoreBtn.addEventListener('click', () => {
    visible += batchSize;
    items.forEach((item, index) => {
      if (index < visible) item.style.display = '';
    });
    if (visible >= items.length) showMoreBtn.style.display = 'none';
  });

  showMoreBtn.dataset.showMoreSetup = 'true';
  return true;
}

document.addEventListener('DOMContentLoaded', () => {
  setupShowMore();

  // Keep observing so AJAX content replacement is also handled
  const productSection = document.querySelector('product-recommendations');
  if (!productSection) return;

  const observer = new MutationObserver(() => {
    setupShowMore();
  });

  observer.observe(productSection, { childList: true, subtree: true });
});
</script>




{% schema %}
{
  "name": "t:names.product_recommendations",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "text"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "button"
    },
    {
      "type": "video"
    },
    {
      "type": "group"
    },
    {
      "type": "spacer"
    },
    {
      "type": "_divider"
