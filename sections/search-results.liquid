{% style %}
  .pagination__ellipsis { color: #000000; }
  .pagination { margin-top: var(--spacing-6, 36px); margin-bottom: var(--spacing-6, 36px); text-align: center; }
  .pagination__list { display: inline-flex; gap: 8px; align-items: center; list-style: none; }
  .pagination__item { padding: 2px; border-radius: 0px; }
  .pagination__item a { text-decoration: none; }
  .pagination__item--current { font-weight: 600; outline: 1px solid var(--color-border, #ddd); }
  .pagination__item--prev a, .pagination__item--next a { font-weight: 500; outline: none; }
{% endstyle %}

{% assign product_shown = section.settings.product_shown %}

{% comment %} Block results-list custom element before any module scripts run {% endcomment %}
<script>
  if (!customElements.get('results-list')) {
    customElements.define('results-list', class extends HTMLElement {});
  }
</script>

{% comment %} Auto-apply availability filter if not already set {% endcomment %}
<script>
  (function() {
    const url = new URL(window.location.href);
    if (!url.searchParams.has("filter.v.availability")) {
      url.searchParams.set("filter.v.availability", "1");
      window.location.replace(url.toString());
    }
  })();
</script>

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section product-grid-container spacing-style color-{{ section.settings.color_scheme }}"
  style="--padding-block-start: {{ section.settings.padding-block-start }}px; --padding-block-end: {{ section.settings.padding-block-end }}px;"
>
  {% render 'skip-to-content-link', href: '#ResultsList', text: 'accessibility.skip_to_results_list' %}

  <div class="collection-wrapper grid gap-style">
    {% paginate search.results by product_shown %}

      {% comment %} Always show filters, even on zero-result searches {% endcomment %}
      {% if search.results_count > 0 %}
        {% content_for 'block', type: 'filters', id: 'filters', results: search, results_size: search.results_count %}
        {% assign products = search.results | where: 'object_type', 'product' %}
      {% else %}
        {% assign nyheter_collection = settings.empty_state_collection | default: collections.all %}
        {% content_for 'block', type: 'filters', id: 'filters', results: search, results_size: nyheter_collection.products.size %}
      {% endif %}

      {% if search.results_count > 0 %}

        {% capture children %}
          {% for product in products %}
            <li
              id="{{ section.id }}-{{ product.id }}"
              class="product-grid__item product-grid__item--{{ forloop.index0 }}"
              data-page="{{ paginate.current_page }}"
              data-product-id="{{ product.id }}"
              ref="cards[]"
              style="--card-index: {{ forloop.index0 | at_most: 8 }}"
            >
              {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
            </li>
          {% endfor %}
        {% endcapture %}

        {% render 'product-grid',
          section: section,
          children: children,
          products: products,
          paginate: paginate,
          hide_viewmore: true
        %}

        {% if paginate.pages > 1 %}
          <nav class="pagination" style="grid-column: 1 / -1" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
            <ul class="pagination__list" role="list">

              {%- if paginate.previous -%}
                <li class="pagination__item pagination__item--prev">
                  <a href="{{ paginate.previous.url | escape }}#ResultsList"
                    rel="prev"
                    aria-label="{{ 'general.pagination.previous' | t }}">
                    <span class="pagination__arrow">◄</span> Föregående
                  </a>
                </li>
              {%- endif -%}

              {%- for part in paginate.parts -%}
                {% if part.is_link %}
                  <li class="pagination__item">
                    <a href="{{ part.url | escape }}#ResultsList"
                      aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                      {{ part.title }}
                    </a>
                  </li>
                {% elsif part.title == paginate.current_page %}
                  <li class="pagination__item pagination__item--current" aria-current="page">
                    {{ part.title }}
                  </li>
                {% else %}
                  <li class="pagination__item pagination__item--ellipsis">
                    <span class="pagination__ellipsis">{{ part.title }}</span>
                  </li>
                {% endif %}
              {%- endfor -%}

              {%- if paginate.next -%}
                <li class="pagination__item pagination__item--next">
                  <a href="{{ paginate.next.url | escape }}#ResultsList"
                    rel="next"
                    aria-label="{{ 'general.pagination.next' | t }}">
                    Nästa <span class="pagination__arrow">►</span>
                  </a>
                </li>
              {%- endif -%}

            </ul>
          </nav>
        {% endif %}

      {% else %}

        {% comment %} Zero-results: empty state message + Nyheter i butiken {% endcomment %}
        <div
          id="ResultsList"
          style="grid-column: 1 / -1; border-top: 1px solid var(--color-border);"
        >
          <div>

            {% comment %} Empty state message {% endcomment %}
            <div class="search-empty-state">
              <p class="search-empty-state__heading">Inga resultat på din sökning</p>
              <p class="search-empty-state__body">
                Inga resultat hittades för "{{ search.terms | escape }}". Kontrollera stavningen eller använd ett annat ord eller fras.
              </p>
            </div>

            {% comment %} Nyheter i butiken {% endcomment %}
            <div class="search-nyheter-section">
              <div class="search-nyheter-section__header">
                <span class="search-nyheter-section__title">Nyheter i butiken</span>
              </div>

              <div
                class="resource-list resource-list--grid search-nyheter-grid"
                id="search-nyheter-grid"
                style="
                  --resource-list-columns: repeat(4, 1fr);
                  --resource-list-columns-mobile: repeat(2, 1fr);
                  --resource-list-column-gap-desktop: {{ section.settings.columns_gap_horizontal }}px;
                  --resource-list-row-gap-desktop: {{ section.settings.columns_gap_vertical }}px;
                  --column-count: 4;
                  --column-count-mobile: 2;
                "
              >
                {% for product in nyheter_collection.products limit: 24 %}
                  <div class="resource-list__item">
                    {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
                  </div>
                {% endfor %}
              </div>

              <div class="show-more-wrapper" style="text-align: center; margin-top: 24px; display: flex; justify-content: center;">
                <button id="search-show-more-nyheter" class="button">VISA FLER</button>
              </div>
            </div>

          </div>
        </div>

      {% endif %}

    {% endpaginate %}
  </div>
</div>

<script>
(function() {
  function setupNyheterShowMore() {
    const grid = document.getElementById('search-nyheter-grid');
    const btn = document.getElementById('search-show-more-nyheter');
    if (!grid || !btn || btn.dataset.setup === 'true') return;

    const items = Array.from(grid.querySelectorAll('.resource-list__item'));
    if (!items.length) return;

    const batchSize = 8;
    let visible = batchSize;

    items.forEach((item, i) => {
      if (i >= visible) item.style.display = 'none';
    });

    if (items.length <= visible) {
      btn.style.display = 'none';
    }

    btn.addEventListener('click', () => {
      visible += batchSize;
      items.forEach((item, i) => {
        if (i < visible) item.style.display = '';
      });
      if (visible >= items.length) btn.style.display = 'none';
    });

    btn.dataset.setup = 'true';
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupNyheterShowMore);
  } else {
    setupNyheterShowMore();
  }
})();
</script>

<script src="{{ 'filter-align.js' | asset_url }}" defer></script>

{% stylesheet %}

/* ── Empty state ── */
.search-empty-state {
  padding-block: var(--padding-6xl);
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--padding-sm);
  border-bottom: 1px solid var(--color-border);
}

.search-empty-state__heading {
  margin: 0;
  font-size: 2rem;
  font-weight: 400;
  line-height: 1.2;
}

.search-empty-state__body {
  margin: 0;
  max-width: 480px;
}

/* ── Nyheter i butiken section ── */
.search-nyheter-section {
  padding-block-start: var(--padding-xl);
  padding-block-end: var(--padding-2xl);
  padding-inline: 15px;
}

@media screen and (min-width: 750px) {
  .search-nyheter-section {
    padding-inline: var(--page-margin, 20px);
  }
}

.search-nyheter-section__header {
  border-bottom: 1px solid var(--color-border);
  padding-block-end: var(--padding-sm);
  margin-block-end: var(--padding-md);
}

.search-nyheter-section__title {
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  font-weight: 500;
}

/* ── Nyheter grid (mirrors resource-list--grid from product-recommendations) ── */
.search-nyheter-grid.resource-list--grid {
  display: grid;
  grid-template-columns: var(--resource-list-columns-mobile, repeat(2, 1fr));
  gap: var(--resource-list-row-gap-desktop, 16px) var(--resource-list-column-gap-desktop, 16px);
}

@media screen and (min-width: 750px) {
  .search-nyheter-grid.resource-list--grid {
    grid-template-columns: var(--resource-list-columns, repeat(4, 1fr));
  }
}

{% endstylesheet %}

{% schema %}
{
  "name": "t:names.search_results",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.edit_empty_state_collection_in_theme_settings"
    },
    {
      "type": "range",
      "id": "product_shown",
      "label": "Products per page",
      "min": 6,
      "max": 50,
      "step": 1,
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "enable_pagination",
      "label": "Enable Pagination",
      "default": false
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:settings.type",
      "options": [
        {
          "value": "grid",
          "label": "t:options.grid"
        },
        {
          "value": "organic",
          "label": "t:options.editorial"
        }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "product_card_size",
      "label": "t:settings.card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "medium",
          "label": "t:options.medium"
        },
        {
          "value": "large",
          "label": "t:options.large"
        },
        {
          "value": "extra-large",
          "label": "t:options.extra_large"
        }
      ],
      "default": "medium",
      "visible_if": "{{ section.settings.layout_type == 'grid' }}"
    },
    {
      "type": "select",
      "id": "mobile_product_card_size",
      "label": "t:settings.mobile_card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "large",
          "label": "t:options.large"
        }
      ],
      "default": "small"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "product_grid_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "centered",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "centered"
    },
    {
      "type": "checkbox",
      "id": "full_width_on_mobile",
      "label": "t:settings.full_width_on_mobile",
      "default": true,
      "visible_if": "{{ section.settings.product_grid_width != 'full-width' }}"
    },
    {
      "type": "range",
      "id": "columns_gap_horizontal",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "columns_gap_vertical",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": []
}
{% endschema %}
