{% comment %}
  Section: Breadcrumbs
  Usage: Add to templates where you want breadcrumbs. The section will auto-hide on index, cart, and list-collections.
  Matches the CSS and HTML structure used by product/search page custom-liquid breadcrumbs.
{% endcomment %}

{% if section.settings.enable %}
  <style>
    .breadcrumbs {
      width: 100%;
      font-size: 14px;
      color: #000000;
      padding: 15px;
      margin: 0;
      border-top: 1px solid #e5e5e5;
      border-bottom: 1px solid #e5e5e5;
    }
    .breadcrumbs a {
      color: var(--color-foreground, #000);
      text-decoration: none;
    }
    .breadcrumbs a:hover {
      color: var(--color-foreground, #000);
      text-decoration: underline;
    }
    .breadcrumbs span {
      color: black;
      font-family: "Inter Variable", sans-serif;
      font-feature-settings: 'ss07' 1;
      font-weight: 400;
    }
    .breadcrumbs .divider {
      margin: 0 6px;
      color: #C1C1C1;
    }
    .breadcrumbs a,
    .breadcrumbs span,
    .breadcrumbs .divider {
      display: inline;
    }
  </style>

  {%- unless template == 'index' or template == 'cart' or template == 'list-collections' -%}
    {%- assign t = template | split: '.' | first -%}

    <nav class="breadcrumbs" role="navigation" aria-label="{{ section.settings.aria_label | escape }}">
      <a href="{{ routes.root_url }}">{{ section.settings.home_label | default: 'Start' }}</a>

      {%- case t -%}
        {%- when 'page' -%}
          {%- comment -%} Sub-pages: show their parent as a crumb {%- endcomment -%}
          {%- if page.handle == 'ladda-upp-bilder' -%}
            <span class="divider">/</span>
            <a href="/pages/salj-byt">Sälj eller byt in</a>
          {%- endif -%}
          <span class="divider">/</span>
          <span>{{ page.title }}</span>

        {%- when 'product' -%}
          {%- assign crumb_collection = nil -%}
          {%- if request.params.collection != blank -%}
            {%- assign crumb_collection = collections[request.params.collection] -%}
          {%- endif -%}
          {%- if crumb_collection == nil and collection and collection.handle -%}
            {%- assign crumb_collection = collection -%}
          {%- endif -%}
          {%- comment -%} Fallback: find a product collection that exists in the nav menu {%- endcomment -%}
          {%- if crumb_collection == nil and section.settings.nav_menu != blank -%}
            {%- assign nav_fallback = linklists[section.settings.nav_menu] -%}
            {%- for pc in product.collections -%}
              {%- if crumb_collection != nil -%}{% break %}{%- endif -%}
              {%- for l1 in nav_fallback.links -%}
                {%- if crumb_collection != nil -%}{% break %}{%- endif -%}
                {%- for l2 in l1.links -%}
                  {%- if l2.url == pc.url -%}
                    {%- assign crumb_collection = pc -%}
                    {%- break -%}
                  {%- endif -%}
                  {%- for l3 in l2.links -%}
                    {%- if l3.url == pc.url -%}
                      {%- assign crumb_collection = pc -%}
                      {%- break -%}
                    {%- endif -%}
                  {%- endfor -%}
                {%- endfor -%}
              {%- endfor -%}
            {%- endfor -%}
          {%- endif -%}
          {%- if crumb_collection != nil -%}
            {%- comment -%} Walk the nav menu to find parent(s) of this collection {%- endcomment -%}
            {%- assign prod_parent_title = nil -%}
            {%- assign prod_parent_url = nil -%}
            {%- assign prod_grandparent_title = nil -%}
            {%- assign prod_grandparent_url = nil -%}
            {%- assign nav = linklists[section.settings.nav_menu] -%}
            {%- if nav != blank -%}
              {%- for l1 in nav.links -%}
                {%- if prod_parent_title != nil -%}{%- break -%}{%- endif -%}
                {%- for l2 in l1.links -%}
                  {%- if prod_parent_title != nil -%}{%- break -%}{%- endif -%}
                  {%- if l2.url == crumb_collection.url -%}
                    {%- assign prod_parent_title = l1.title -%}
                    {%- assign prod_parent_url = l1.url -%}
                  {%- else -%}
                    {%- for l3 in l2.links -%}
                      {%- if l3.url == crumb_collection.url -%}
                        {%- assign prod_grandparent_title = l1.title -%}
                        {%- assign prod_grandparent_url = l1.url -%}
                        {%- assign prod_parent_title = l2.title -%}
                        {%- assign prod_parent_url = l2.url -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endfor -%}
            {%- endif -%}
            {%- if prod_grandparent_title -%}
              <span class="divider">/</span>
              {%- if prod_grandparent_url != blank -%}
                <a href="{{ prod_grandparent_url }}">{{ prod_grandparent_title }}</a>
              {%- else -%}
                <span>{{ prod_grandparent_title }}</span>
              {%- endif -%}
            {%- endif -%}
            {%- if prod_parent_title -%}
              <span class="divider">/</span>
              {%- if prod_parent_url != blank -%}
                <a href="{{ prod_parent_url }}">{{ prod_parent_title }}</a>
              {%- else -%}
                <span>{{ prod_parent_title }}</span>
              {%- endif -%}
            {%- endif -%}
            <span class="divider">/</span>
            <a href="{{ crumb_collection.url }}">{{ crumb_collection.title }}</a>
          {%- elsif product.type != blank -%}
            <span class="divider">/</span>
            <a href="{{ routes.all_products_collection_url }}?filter.p.product_type={{ product.type | url_encode }}">{{ product.type }}</a>
          {%- endif -%}
          <span class="divider">/</span>
          <span>{{ product.title }}</span>

        {%- when 'collection' -%}
          {%- if collection.handle -%}
            {%- comment -%} Walk the nav menu to find parent(s) of this collection {%- endcomment -%}
            {%- assign crumb_parent_title = nil -%}
            {%- assign crumb_parent_url = nil -%}
            {%- assign crumb_grandparent_title = nil -%}
            {%- assign crumb_grandparent_url = nil -%}
            {%- assign nav = linklists[section.settings.nav_menu] -%}
            {%- if nav != blank -%}
              {%- for l1 in nav.links -%}
                {%- if crumb_parent_title != nil -%}{%- break -%}{%- endif -%}
                {%- for l2 in l1.links -%}
                  {%- if crumb_parent_title != nil -%}{%- break -%}{%- endif -%}
                  {%- if l2.url == collection.url -%}
                    {%- assign crumb_parent_title = l1.title -%}
                    {%- assign crumb_parent_url = l1.url -%}
                  {%- else -%}
                    {%- for l3 in l2.links -%}
                      {%- if l3.url == collection.url -%}
                        {%- assign crumb_grandparent_title = l1.title -%}
                        {%- assign crumb_grandparent_url = l1.url -%}
                        {%- assign crumb_parent_title = l2.title -%}
                        {%- assign crumb_parent_url = l2.url -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endfor -%}
            {%- endif -%}

            {%- if crumb_grandparent_title -%}
              <span class="divider">/</span>
              {%- if crumb_grandparent_url != blank -%}
                <a href="{{ crumb_grandparent_url }}">{{ crumb_grandparent_title }}</a>
              {%- else -%}
                <span>{{ crumb_grandparent_title }}</span>
              {%- endif -%}
            {%- endif -%}

            {%- if crumb_parent_title -%}
              <span class="divider">/</span>
              {%- if crumb_parent_url != blank -%}
                <a href="{{ crumb_parent_url }}">{{ crumb_parent_title }}</a>
              {%- else -%}
                <span>{{ crumb_parent_title }}</span>
              {%- endif -%}
            {%- endif -%}

            {%- if current_tags -%}
              <span class="divider">/</span>
              <a href="{{ collection.url }}">{{ collection.title }}</a>
              <span class="divider">/</span>
              <span>{{ current_tags | join: " + " }}</span>
            {%- else -%}
              <span class="divider">/</span>
              <span>{{ collection.title }}</span>
            {%- endif -%}
          {%- endif -%}

        {%- when 'blog' -%}
          {%- if current_tags -%}
            <span class="divider">/</span>
            <a href="{{ blog.url }}">{{ blog.title }}</a>
            <span class="divider">/</span>
            <span>{{ current_tags | join: " + " }}</span>
          {%- else -%}
            <span class="divider">/</span>
            <span>{{ blog.title }}</span>
          {%- endif -%}

        {%- when 'article' -%}
          <span class="divider">/</span>
          <a href="{{ blog.url }}">{{ blog.title }}</a>
          <span class="divider">/</span>
          <span>{{ article.title }}</span>

        {%- when 'search' -%}
          <span class="divider">/</span>
          <span>Sökning: "{{ search.terms }}"</span>

        {%- when '404' -%}
          <span class="divider">/</span>
          <span>404</span>

        {%- else -%}
          <span class="divider">/</span>
          <span>{{ page_title }}</span>
      {%- endcase -%}
    </nav>

    <script type="application/ld+json">
    {%- assign bc_pos = 1 -%}
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": {{ bc_pos }},
          "name": {{ section.settings.home_label | default: 'Start' | json }},
          "item": {{ request.origin | json }}
        }
        {%- case t -%}
          {%- when 'page' -%}
            {%- if page.handle == 'ladda-upp-bilder' -%}
              {%- assign bc_pos = bc_pos | plus: 1 -%}
              ,{
                "@type": "ListItem",
                "position": {{ bc_pos }},
                "name": "Sälj eller byt in",
                "item": {{ request.origin | append: '/pages/salj-byt' | json }}
              }
            {%- endif -%}
            {%- assign bc_pos = bc_pos | plus: 1 -%}
            ,{
              "@type": "ListItem",
              "position": {{ bc_pos }},
              "name": {{ page.title | json }}
            }
          {%- when 'product' -%}
            {%- if prod_grandparent_title -%}
              {%- assign bc_pos = bc_pos | plus: 1 -%}
              ,{
                "@type": "ListItem",
                "position": {{ bc_pos }},
                "name": {{ prod_grandparent_title | json }},
                "item": {{ request.origin | append: prod_grandparent_url | json }}
              }
            {%- endif -%}
            {%- if prod_parent_title -%}
              {%- assign bc_pos = bc_pos | plus: 1 -%}
              ,{
                "@type": "ListItem",
                "position": {{ bc_pos }},
                "name": {{ prod_parent_title | json }},
                "item": {{ request.origin | append: prod_parent_url | json }}
              }
            {%- endif -%}
            {%- if crumb_collection != nil -%}
              {%- assign bc_pos = bc_pos | plus: 1 -%}
              ,{
                "@type": "ListItem",
                "position": {{ bc_pos }},
                "name": {{ crumb_collection.title | json }},
                "item": {{ request.origin | append: crumb_collection.url | json }}
              }
            {%- endif -%}
            {%- assign bc_pos = bc_pos | plus: 1 -%}
            ,{
              "@type": "ListItem",
              "position": {{ bc_pos }},
              "name": {{ product.title | json }}
            }
          {%- when 'collection' -%}
            {%- if crumb_grandparent_title -%}
              {%- assign bc_pos = bc_pos | plus: 1 -%}
              ,{
                "@type": "ListItem",
                "position": {{ bc_pos }},
                "name": {{ crumb_grandparent_title | json }},
                "item": {{ request.origin | append: crumb_grandparent_url | json }}
              }
            {%- endif -%}
            {%- if crumb_parent_title -%}
              {%- assign bc_pos = bc_pos | plus: 1 -%}
              ,{
                "@type": "ListItem",
                "position": {{ bc_pos }},
                "name": {{ crumb_parent_title | json }},
                "item": {{ request.origin | append: crumb_parent_url | json }}
              }
            {%- endif -%}
            {%- assign bc_pos = bc_pos | plus: 1 -%}
            ,{
              "@type": "ListItem",
              "position": {{ bc_pos }},
              "name": {{ collection.title | json }},
              "item": {{ request.origin | append: collection.url | json }}
            }
          {%- when 'blog' -%}
            {%- assign bc_pos = bc_pos | plus: 1 -%}
            ,{
              "@type": "ListItem",
              "position": {{ bc_pos }},
              "name": {{ blog.title | json }},
              "item": {{ request.origin | append: blog.url | json }}
            }
          {%- when 'article' -%}
            {%- assign bc_pos = bc_pos | plus: 1 -%}
            ,{
              "@type": "ListItem",
              "position": {{ bc_pos }},
              "name": {{ blog.title | json }},
              "item": {{ request.origin | append: blog.url | json }}
            }
            {%- assign bc_pos = bc_pos | plus: 1 -%}
            ,{
              "@type": "ListItem",
              "position": {{ bc_pos }},
              "name": {{ article.title | json }}
            }
          {%- when 'search' -%}
            {%- assign bc_pos = bc_pos | plus: 1 -%}
            ,{
              "@type": "ListItem",
              "position": {{ bc_pos }},
              "name": {{ 'content.search' | t | json }}
            }
        {%- endcase -%}
      ]
    }
    </script>
  {%- endunless -%}
{% endif %}

{% schema %}
{
  "name": "Breadcrumbs",
  "tag": "section",
  "class": "section-breadcrumbs",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable breadcrumbs",
      "default": true
    },
    {
      "type": "link_list",
      "id": "nav_menu",
      "label": "Navigation menu",
      "info": "Select the same menu used in your header. Used to build parent breadcrumbs for collections."
    },
    {
      "type": "text",
      "id": "home_label",
      "label": "Home label",
      "default": "Start"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA label",
      "default": "Breadcrumbs"
    }
  ],
  "presets": [
    {
      "name": "Breadcrumbs",
      "category": "Text"
    }
  ]
}
{% endschema %}
