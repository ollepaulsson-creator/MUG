{% comment %}
  Section: Breadcrumbs
  Usage: Add to templates where you want breadcrumbs. The section will auto-hide on index, cart, and list-collections.
  Matches the CSS and HTML structure used by product/search page custom-liquid breadcrumbs.
{% endcomment %}

{% if section.settings.enable %}
  <style>
    .breadcrumbs {
      width: 100%;
      font-size: 14px;
      color: #000000;
      padding: 15px;
      margin: 0;
      border-top: 1px solid #e5e5e5;
      border-bottom: 1px solid #e5e5e5;
    }
    .breadcrumbs a {
      color: rgb(0 0 0 / 0.81);
      text-decoration: none;
    }
    .breadcrumbs a:hover {
      color: rgb(0 0 0 / 0.81);
      text-decoration: underline;
    }
    .breadcrumbs span {
      color: black;
      font-family: "Inter Variable", sans-serif;
      font-feature-settings: 'ss07' 1;
      font-weight: 400;
    }
    .breadcrumbs .divider {
      margin: 0 6px;
      color: #C1C1C1;
    }
    .breadcrumbs a,
    .breadcrumbs span,
    .breadcrumbs .divider {
      display: inline;
    }
  </style>

  {%- unless template == 'index' or template == 'cart' or template == 'list-collections' -%}
    {%- assign t = template | split: '.' | first -%}

    <nav class="breadcrumbs" role="navigation" aria-label="{{ section.settings.aria_label | escape }}">
      <a href="{{ routes.root_url }}">{{ section.settings.home_label | default: 'Home' }}</a>

      {%- case t -%}
        {%- when 'page' -%}
          <span class="divider">/</span>
          <span>{{ page.title }}</span>

        {%- when 'product' -%}
          {%- assign crumb_collection = nil -%}
          {%- if request.params.collection != blank -%}
            {%- assign crumb_collection = collections[request.params.collection] -%}
          {%- endif -%}
          {%- if crumb_collection == nil and collection and collection.handle -%}
            {%- assign crumb_collection = collection -%}
          {%- endif -%}
          {%- if crumb_collection != nil -%}
            <span class="divider">/</span>
            <a href="{{ crumb_collection.url }}">{{ crumb_collection.title }}</a>
          {%- elsif product.type != blank -%}
            <span class="divider">/</span>
            <a href="{{ routes.all_products_collection_url }}?filter.p.product_type={{ product.type | url_encode }}">{{ product.type }}</a>
          {%- endif -%}
          <span class="divider">/</span>
          <span>{{ product.title }}</span>

        {%- when 'collection' -%}
          {%- if collection.handle -%}
            {%- if current_tags -%}
              <span class="divider">/</span>
              <a href="{{ collection.url }}">{{ collection.title }}</a>
              <span class="divider">/</span>
              {%- capture tag_url -%}{{ collection.url }}/{{ current_tags | join: "+" }}{%- endcapture -%}
              <span>{{ current_tags | join: " + " }}</span>
            {%- else -%}
              <span class="divider">/</span>
              <span>{{ collection.title }}</span>
            {%- endif -%}
          {%- endif -%}

        {%- when 'blog' -%}
          {%- if current_tags -%}
            <span class="divider">/</span>
            <a href="{{ blog.url }}">{{ blog.title }}</a>
            <span class="divider">/</span>
            <span>{{ current_tags | join: " + " }}</span>
          {%- else -%}
            <span class="divider">/</span>
            <span>{{ blog.title }}</span>
          {%- endif -%}

        {%- when 'article' -%}
          <span class="divider">/</span>
          <a href="{{ blog.url }}">{{ blog.title }}</a>
          <span class="divider">/</span>
          <span>{{ article.title }}</span>

        {%- when 'search' -%}
          <span class="divider">/</span>
          <span>Sökning: "{{ search.terms }}"</span>

        {%- when '404' -%}
          <span class="divider">/</span>
          <span>404</span>

        {%- else -%}
          <span class="divider">/</span>
          <span>{{ page_title }}</span>
      {%- endcase -%}
    </nav>
  {%- endunless -%}
{% endif %}

{% schema %}
{
  "name": "Breadcrumbs",
  "tag": "section",
  "class": "section-breadcrumbs",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable breadcrumbs",
      "default": true
    },
    {
      "type": "text",
      "id": "home_label",
      "label": "Home label",
      "default": "Home"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA label",
      "default": "Breadcrumbs"
    }
  ],
  "presets": [
    {
      "name": "Breadcrumbs",
      "category": "Text"
    }
  ]
}
{% endschema %}
