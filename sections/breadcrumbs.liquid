{% comment %}
  Section: Breadcrumbs
  Usage: Add to templates where you want breadcrumbs. The section will auto-hide on index, cart, list-collections, and 404.
{% endcomment %}

{% if section.settings.enable %}
  <style>
    .breadcrumbs {
      margin: 0 0 {{ section.settings.margin_bottom }}px;
    }
    .breadcrumbs__list {
      list-style-type: none;
      margin: 0;
      padding: 0;
    }
    .breadcrumbs__item {
      display: inline-block;
    }
    .breadcrumbs__item:not(:last-child):after {
      border-style: solid;
      border-width: .10em .10em 0 0;
      content: '';
      display: inline-block;
      height: .20em;
      margin: 0 .20em;
      position: relative;
      transform: rotate(45deg);
      vertical-align: middle;
      width: .20em;
    }
    .breadcrumbs__link {
      {% if section.settings.underline_links %}text-decoration: underline;{% else %}text-decoration: none;{% endif %}
    }
    .breadcrumbs__link[aria-current="page"] {
      color: inherit;
      font-weight: normal;
      text-decoration: none;
    }
    .breadcrumbs__link[aria-current="page"]:hover,
    .breadcrumbs__link[aria-current="page"]:focus {
      text-decoration: underline;
    }
  </style>

  {%- unless template == 'index' or template == 'cart' or template == 'list-collections' -%}
    {%- assign t = template | split: '.' | first -%}

    {% if section.settings.wrap_in_container %}<div class="{{ section.settings.container_class | default: 'page-width' }}">{% endif %}
    <nav class="breadcrumbs" role="navigation" aria-label="{{ section.settings.aria_label | escape }}">
      <ol class="breadcrumbs__list">
        <li class="breadcrumbs__item">
          <a class="breadcrumbs__link" href="{{ routes.root_url }}">{{ section.settings.home_label | default: 'Home' }}</a>
        </li>

        {%- case t -%}
          {%- when 'page' -%}
            <li class="breadcrumbs__item">
              <a class="breadcrumbs__link" href="{{ page.url }}" aria-current="page">{{ page.title }}</a>
            </li>

          {%- when 'product' -%}
            {%- comment -%}
              Respect navigation context: prefer collection from URL param, then any associated collection.
            {%- endcomment -%}
            {%- assign crumb_collection = nil -%}
            {%- if request.params.collection != blank -%}
              {%- assign crumb_collection = collections[request.params.collection] -%}
            {%- endif -%}
            {%- if crumb_collection == nil and collection and collection.handle -%}
              {%- assign crumb_collection = collection -%}
            {%- endif -%}
            {%- if crumb_collection != nil -%}
              <li class="breadcrumbs__item">
                <a class="breadcrumbs__link" href="{{ crumb_collection.url }}">{{ crumb_collection.title }}</a>
              </li>
            {%- elsif product.type != blank -%}
              <li class="breadcrumbs__item">
                <a class="breadcrumbs__link" href="{{ routes.all_products_collection_url }}?filter.p.product_type={{ product.type | url_encode }}">{{ product.type }}</a>
              </li>
            {%- endif -%}
            <li class="breadcrumbs__item">
              <a class="breadcrumbs__link" href="{{ product.url }}" aria-current="page">{{ product.title }}</a>
            </li>

          {%- when 'collection' -%}
            {%- if collection.handle -%}
              {%- if current_tags -%}
                <li class="breadcrumbs__item">
                  <a class="breadcrumbs__link" href="{{ collection.url }}">{{ collection.title }}</a>
                </li>
                <li class="breadcrumbs__item">
                  {%- capture tag_url -%}{{ collection.url }}/{{ current_tags | join: "+" }}{%- endcapture -%}
                  <a class="breadcrumbs__link" href="{{ tag_url }}" aria-current="page">{{ current_tags | join: " + " }}</a>
                </li>
              {%- else -%}
                <li class="breadcrumbs__item">
                  <a class="breadcrumbs__link" href="{{ collection.url }}" aria-current="page">{{ collection.title }}</a>
                </li>
              {%- endif -%}
            {%- endif -%}

          {%- when 'blog' -%}
            {%- if current_tags -%}
              <li class="breadcrumbs__item">
                <a class="breadcrumbs__link" href="{{ blog.url }}">{{ blog.title }}</a>
              </li>
              <li class="breadcrumbs__item">
                <a class="breadcrumbs__link" href="{{ blog.url }}/tagged/{{ current_tags | first | handle }}" aria-current="page">{{ current_tags | join: " + " }}</a>
              </li>
            {%- else -%}
              <li class="breadcrumbs__item">
                <a class="breadcrumbs__link" href="{{ blog.url }}" aria-current="page">{{ blog.title }}</a>
              </li>
            {%- endif -%}

          {%- when 'article' -%}
            <li class="breadcrumbs__item">
              <a class="breadcrumbs__link" href="{{ blog.url }}">{{ blog.title }}</a>
            </li>
            <li class="breadcrumbs__item">
              <a class="breadcrumbs__link" href="{{ article.url }}" aria-current="page">{{ article.title }}</a>
            </li>

          {%- when 'search' -%}
            <li class="breadcrumbs__item">
              <a class="breadcrumbs__link" href="{{ request.path }}" aria-current="page">Sökning: "{{ search.terms }}"</a>
            </li>

          {%- when '404' -%}
            <li class="breadcrumbs__item">
              <span class="breadcrumbs__link" aria-current="page">404</span>
            </li>

          {%- else -%}
            <li class="breadcrumbs__item">
              <a class="breadcrumbs__link" href="{{ request.path }}" aria-current="page">{{ page_title }}</a>
            </li>
        {%- endcase -%}
      </ol>
    </nav>
    {% if section.settings.wrap_in_container %}</div>{% endif %}
  {%- endunless -%}
{% endif %}

{% schema %}
{
  "name": "Breadcrumbs",
  "tag": "section",
  "class": "section-breadcrumbs",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable breadcrumbs",
      "default": true
    },
    {
      "type": "text",
      "id": "home_label",
      "label": "Home label",
      "default": "Home"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA label",
      "default": "Breadcrumbs"
    },
    {
      "type": "checkbox",
      "id": "underline_links",
      "label": "Underline links",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "wrap_in_container",
      "label": "Wrap in page-width container",
      "default": true
    },
    {
      "type": "text",
      "id": "container_class",
      "label": "Custom container class (optional)",
      "default": "page-width",
      "info": "Used when \"Wrap in page-width container\" is enabled."
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom spacing (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Breadcrumbs",
      "category": "Text"
    }
  ]
}
{% endschema %}