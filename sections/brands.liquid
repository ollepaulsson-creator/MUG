{% comment %}
  Brands (Varumärken) section.
  Fetches all unique product vendors from the Shopify Products JSON API,
  groups them alphabetically and renders letter headings with collection links.
{% endcomment %}

<div
  class="brands-page page-width"
  id="brands-list"
  aria-live="polite"
  aria-busy="true"
>
  <p class="brands-loading">Laddar varumärken…</p>
</div>

<script>
(function () {
  'use strict';

  async function fetchAllVendors() {
    const vendors = new Set();
    let page = 1;

    while (true) {
      const res = await fetch(
        '/products.json?limit=250&fields=vendor&page=' + page
      );
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const data = await res.json();
      const products = data.products || [];

      products.forEach(function (p) {
        if (p.vendor && p.vendor.trim()) vendors.add(p.vendor.trim());
      });

      if (products.length < 250) break;
      page++;
    }

    return Array.from(vendors).sort(function (a, b) {
      return a.localeCompare(b, 'sv', { sensitivity: 'base' });
    });
  }

  function groupByLetter(vendors) {
    var groups = {};
    vendors.forEach(function (vendor) {
      var first = vendor.charAt(0).toUpperCase();
      var key = /^[A-ZÅÄÖ]$/.test(first) ? first : '1';
      if (!groups[key]) groups[key] = [];
      groups[key].push(vendor);
    });
    return groups;
  }

  function renderBrands(groups) {
    var container = document.getElementById('brands-list');
    var letters = Object.keys(groups).sort(function (a, b) {
      if (a === '1') return -1;
      if (b === '1') return 1;
      return a.localeCompare(b, 'sv');
    });

    var html = '';
    letters.forEach(function (letter) {
      html += '<div class="brands-group">';
      html += '<h2 class="brands-group__letter">' + letter + '</h2>';
      html += '<ul class="brands-group__list">';
      groups[letter].forEach(function (vendor) {
        var href = '/collections/vendors?q=' + encodeURIComponent(vendor);
        html +=
          '<li><a href="' +
          href +
          '">' +
          vendor.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;') +
          '</a></li>';
      });
      html += '</ul></div>';
    });

    container.setAttribute('aria-busy', 'false');
    container.innerHTML = html;
  }

  fetchAllVendors()
    .then(function (vendors) {
      var groups = groupByLetter(vendors);
      renderBrands(groups);
    })
    .catch(function () {
      var container = document.getElementById('brands-list');
      container.setAttribute('aria-busy', 'false');
      container.innerHTML = '<p>Kunde inte ladda varumärken. Försök igen senare.</p>';
    });
})();
</script>

{% style %}
  .brands-page {
    padding-block-start: {{ section.settings.padding-block-start }}px;
    padding-block-end: {{ section.settings.padding-block-end }}px;
  }

  .brands-loading {
    color: var(--color-foreground);
    opacity: 0.5;
    padding-block: 2rem;
  }

  /* Letter groups arranged in a 3-column grid, matching the live site layout */
  #brands-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem 3rem;
    align-items: start;
  }

  /* Loading state: reset grid so the loading paragraph is full-width */
  #brands-list:has(.brands-loading) {
    display: block;
  }

  @media screen and (max-width: 749px) {
    #brands-list {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem 2rem;
    }
  }

  .brands-group {
    /* each group is one grid cell — no extra margin needed */
  }

  .brands-group__letter {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 0;
    margin-bottom: 0.6rem;
    padding-bottom: 0;
    letter-spacing: 0.02em;
  }

  .brands-group__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .brands-group__list li {
    padding-block: 0.15rem;
    line-height: 1.5;
  }

  .brands-group__list a {
    color: var(--color-foreground);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: transparent;
    transition: text-decoration-color var(--animation-speed-medium, 150ms) ease;
  }

  .brands-group__list a:hover {
    text-decoration-color: currentColor;
  }
{% endstyle %}

{% schema %}
{
  "name": "Varumärken",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top_padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom_padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": []
}
{% endschema %}
