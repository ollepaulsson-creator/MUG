{% comment %}
  Brands (Varumärken) section.
  Renders all unique product vendors server-side via shop.vendors (sorted
  alphabetically by Shopify), grouped under letter headings with links to the
  built-in vendor collection. Replaces an earlier client-side version that
  crawled /products.json (20+ requests on a 5000+ product store) and left the
  page on "Laddar varumärken…" for a long time.
{% endcomment %}

<div class="section page-width-content">
  <div class="brands-page" id="brands-list">
  {%- liquid
    assign letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZÅÄÖ'
    assign prev_key = nil
  -%}
  {%- for vendor in shop.vendors -%}
    {%- liquid
      assign first = vendor | slice: 0, 1 | upcase
      if letters contains first
        assign key = first
      else
        assign key = '1'
      endif
    -%}
    {%- if key != prev_key -%}
      {%- unless forloop.first -%}
        </ul></div>
      {%- endunless -%}
      <div class="brands-group">
        <h2 class="brands-group__letter">{{ key }}</h2>
        <ul class="brands-group__list">
    {%- endif -%}
    <li><a href="{{ vendor | url_for_vendor }}">{{ vendor }}</a></li>
    {%- assign prev_key = key -%}
    {%- if forloop.last -%}
      </ul></div>
    {%- endif -%}
  {%- endfor -%}
  </div>
</div>

{% style %}
  .brands-page {
    padding-block-start: {{ section.settings.padding-block-start }}px;
    padding-block-end: {{ section.settings.padding-block-end }}px;
  }

  /* Letter groups arranged in a 3-column grid, matching the live site layout */
  #brands-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem 3rem;
    align-items: start;
  }

  @media screen and (max-width: 749px) {
    #brands-list {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem 2rem;
    }
  }

  .brands-group__letter {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 0;
    margin-bottom: 0.6rem;
    padding-bottom: 0;
    letter-spacing: 0.02em;
  }

  .brands-group__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .brands-group__list li {
    padding-block: 0.15rem;
    line-height: 1.5;
  }

  .brands-group__list a {
    color: var(--color-foreground);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: transparent;
    transition: text-decoration-color var(--animation-speed-medium, 150ms) ease;
  }

  .brands-group__list a:hover {
    text-decoration-color: currentColor;
  }
{% endstyle %}

{% schema %}
{
  "name": "Varumärken",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top_padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom_padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": []
}
{% endschema %}
