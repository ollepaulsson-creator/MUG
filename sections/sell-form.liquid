{% comment %}
  Sälj/byt in — submission form (Ladda upp bilder och beskriv ditt instrument).
  Posts multipart form data to a Cloudflare Worker (see scripts/sell-form-worker/)
  which emails order@mug.se with the photos attached and sends a copy to the
  submitter. Photos are compressed client-side (max 1600px JPEG) before upload
  so phone photos stay well under the size limits.
{% endcomment %}

<div class="section page-width-content">
  <div class="sell-form">
    <a class="sell-form__back" href="{{ section.settings.back_url | default: '/pages/salj-byt' }}">
      <svg viewBox="0 0 16 16" width="15" height="15" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M7.5 2.5 2 8l5.5 5.5M2.5 8H14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Tillbaka
    </a>

    <h1 class="sell-form__title">Ladda upp bilder och beskriv ditt instrument</h1>

    <p class="sell-form__intro">
      Har du något att sälja? Vi vill ha bilder och den info du har så kan vi ta nästa steg.
      Vi värderar instrumenten och gör även i vissa fall hembesök. Vi har ett nära samarbete
      med Godsroteln hos Polisen för att försäkra oss om att vi inte hanterar stulet gods,
      och har många gånger hjälpt ägare få tillbaks sina ägodelar. Ge en detaljerad
      beskrivning av allt som du tycker vi bör känna till, så återkommer vi med ett prisförslag.
    </p>

    <form class="sell-form__form" novalidate data-endpoint="{{ section.settings.endpoint | escape }}">
      {%- comment -%} Honeypot — hidden from humans, bots fill it {%- endcomment -%}
      <input type="text" name="company" class="sell-form__hp" tabindex="-1" autocomplete="off" aria-hidden="true">

      <label class="sell-form__label" for="sell-name">Ditt namn:</label>
      <input class="sell-form__input" id="sell-name" name="name" type="text" placeholder="Förnamn och efternamn" autocomplete="name" required>
      <p class="sell-form__field-error" id="err-sell-name" hidden>Fyll i ditt namn.</p>

      <label class="sell-form__label" for="sell-email">Din e-postadress:</label>
      <input class="sell-form__input" id="sell-email" name="email" type="email" placeholder="E-postadress" autocomplete="email" required>
      <p class="sell-form__field-error" id="err-sell-email" hidden>Fyll i en giltig e-postadress.</p>

      <label class="sell-form__label" for="sell-phone">Ditt telefonnummer:</label>
      <input class="sell-form__input" id="sell-phone" name="phone" type="tel" placeholder="Telefonnummer" autocomplete="tel" required>
      <p class="sell-form__field-error" id="err-sell-phone" hidden>Fyll i ditt telefonnummer.</p>

      <h2 class="sell-form__subheading">Beskriv ditt instrument</h2>

      <label class="sell-form__label" for="sell-model">Märke och modell:</label>
      <p class="sell-form__help">
        Här anger du vad du anser vara instrumentets tillverkare, modell och om du vet
        instrumentets tillverkningsår.
      </p>
      <input class="sell-form__input" id="sell-model" name="model" type="text" placeholder="Instrumentets märke och modell och år" required>
      <p class="sell-form__field-error" id="err-sell-model" hidden>Fyll i märke och modell.</p>

      <label class="sell-form__label" for="sell-description">Beskrivning:</label>
      <p class="sell-form__help">
        Ge en detaljerad beskrivning av allt som du tycker vi bör känna till
        (ev skavanker, tillbehör, modifikationer, originalcase, etc)
      </p>
      <textarea class="sell-form__input sell-form__textarea" id="sell-description" name="description" rows="6" placeholder="Beskriv instrumentetet"></textarea>

      <span class="sell-form__label">Bilder:</span>
      <p class="sell-form__help">
        Nedanstående exempel visar vilka bilder och vinklar vi vill se. Bifoga gärna en bild
        på serienummer/etikett/modellbetecking för att underlätta processen.
      </p>

      <div class="sell-form__angles">
        <img
          src="{{ 'sell-form-angles.png' | asset_url }}"
          alt="Exempel på bildvinklar: framifrån, vinklat, detaljer och skavanker"
          loading="lazy"
          width="1378"
          height="365"
          class="sell-form__angles-image"
        >
      </div>

      <div class="sell-form__dropzone" data-dropzone tabindex="0" role="button" aria-label="Ladda upp bilder på ditt instrument">
        <div class="sell-form__dropzone-inner">
          <strong class="sell-form__dropzone-title">Ladda upp bilder på ditt instrument</strong>
          <span class="sell-form__dropzone-hint">Dra eller släpp bilderna här eller bläddra efter en fil.</span>
          <span class="sell-form__browse button">Välj bilder&hellip;</span>
        </div>
        <input type="file" accept="image/*" multiple data-file-input class="sell-form__file-input" aria-hidden="true" tabindex="-1">
      </div>

      <ul class="sell-form__previews" data-previews></ul>

      <p class="sell-form__error" data-error hidden></p>

      <button type="submit" class="sell-form__submit button">Skicka bilder</button>

      <p class="sell-form__note">En kopia av dina svar kommer att skickas till den e-postadress du angett.</p>
    </form>

    <div class="sell-form__success" data-success hidden>
      <h2 class="sell-form__success-title">
        <span class="sell-form__success-check" aria-hidden="true">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M2.81641 8.61667L4.78353 11.1458C4.84991 11.232 4.93497 11.3022 5.03231 11.3509C5.12965 11.3995 5.23675 11.4255 5.34557 11.4268C5.45264 11.4281 5.55864 11.4054 5.65586 11.3606C5.75308 11.3157 5.83908 11.2497 5.90761 11.1674L12.1837 3.57275" stroke="white" stroke-width="1.65" stroke-linecap="square"/>
          </svg>
        </span>
        Tack så mycket!
      </h2>
      <p class="sell-form__success-text">
        Har frågor om hur det går till; Chatta med oss, ring på
        <a href="tel:+46317110309">031-711 03 09</a>, maila till
        <a href="mailto:order@mug.se">order@mug.se</a> eller kom helt enkelt in till oss i butiken.
      </p>
      <button type="button" class="sell-form__submit sell-form__reset" data-reset>Ladda upp fler instrument</button>
    </div>
  </div>
</div>

{% stylesheet %}
  .sell-form {
    max-width: 640px;
    padding-block: 50px 100px;
  }

  .sell-form__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #f2f2f2;
    color: var(--color-foreground);
    text-decoration: none;
    font-size: 14px;
    padding: 8px 14px;
    margin-bottom: 28px;
  }

  .sell-form__back:hover {
    background: #e8e8e8;
  }

  .sell-form__title {
    font-size: var(--font-h3--size, 2rem);
    margin: 0 0 20px;
  }

  .sell-form__intro {
    margin: 0 0 32px;
    line-height: 1.6;
  }

  .sell-form__subheading {
    font-size: 15px;
    font-weight: 600;
    margin: 32px 0 0;
  }

  .sell-form__label {
    display: block;
    font-weight: 600;
    font-size: 15px;
    margin: 22px 0 0;
  }

  .sell-form__help {
    margin: 6px 0 0;
    color: rgb(var(--color-foreground-rgb) / 0.65);
    font-size: 14px;
    line-height: 1.5;
  }

  /* Fields following a help text get double breathing room */
  .sell-form__help + .sell-form__input,
  .sell-form__help + .sell-form__textarea {
    margin-top: 12px;
  }

  .sell-form__field-error {
    color: #ee2f53;
    font-size: 15px;
    margin: 6px 0 0;
  }

  .sell-form__input--invalid {
    border-color: #ee2f53 !important;
    outline: 2px solid #ee2f53 !important;
    outline-offset: -2px !important;
  }



  .sell-form__input {
    display: block;
    width: 100%;
    margin-top: 6px;
    padding: 8px 10px;
    font: inherit;
    font-size: 15px;
    color: var(--color-foreground);
    background: var(--color-background);
    border: 1px solid #d9d9d9;
    border-radius: 4px;
  }

  .sell-form__input::placeholder {
    color: rgb(var(--color-foreground-rgb) / 0.4);
  }

  .sell-form__textarea {
    resize: vertical;
    min-height: 140px;
  }

  .sell-form__hp {
    position: absolute !important;
    left: -9999px !important;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .sell-form__angles {
    margin-top: 20px;
  }

  .sell-form__angles-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .sell-form__dropzone {
    margin-top: 20px;
    border: 1px dashed #b7b7b7;
    border-radius: 4px;
    background: #fafafa;
    padding: 56px 24px;
    text-align: center;
    cursor: pointer;
    transition: background 150ms ease;
  }

  .sell-form__dropzone:hover,
  .sell-form__dropzone.is-dragover {
    background: #f1f1f1;
  }

  .sell-form__dropzone-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .sell-form__dropzone-title {
    font-size: 15px;
    font-weight: 600;
  }

  .sell-form__dropzone-hint {
    color: rgb(var(--color-foreground-rgb) / 0.55);
    font-size: 14px;
  }

  .sell-form .sell-form__dropzone .sell-form__browse.button,
  .sell-form__browse {
    margin-top: 14px;
    background: var(--color-background);
    color: var(--color-foreground);
    border: 1px solid #d9d9d9;
    font-size: 13px !important;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 9px 16px;
    cursor: pointer;
  }

  .sell-form__file-input {
    display: none;
  }

  .sell-form__previews {
    list-style: none;
    margin: 16px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .sell-form__previews:empty {
    display: none;
  }

  .sell-form__previews li {
    display: flex;
    align-items: center;
    gap: 12px;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    padding: 8px 12px;
    background: var(--color-background);
    overflow: hidden;
    animation: sell-card-in 240ms ease;
  }

  @keyframes sell-card-in {
    from {
      opacity: 0;
      max-height: 0;
      padding-block: 0;
      border-width: 0;
    }
    to {
      opacity: 1;
      max-height: 80px;
      padding-block: 8px;
      border-width: 1px;
    }
  }

  .sell-form__previews img {
    width: 48px;
    height: 48px;
    border-radius: 4px;
    object-fit: cover;
    display: block;
    flex-shrink: 0;
  }

  .sell-form__preview-meta {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sell-form__preview-name {
    font-size: 14px;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sell-form__preview-size {
    font-size: 13px;
    color: rgb(var(--color-foreground-rgb) / 0.55);
  }

  .sell-form__previews button {
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    border: 0;
    border-radius: 6px;
    background: transparent;
    color: var(--color-foreground);
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sell-form__previews button:hover {
    background: #f2f2f2;
  }

  .sell-form__error {
    color: #ee2f53;
    font-size: 15px;
    margin: 16px 0 0;
  }

  .sell-form__submit {
    display: block;
    width: 100%;
    margin-top: 30px;
    padding: 16px;
    background: var(--color-foreground);
    color: var(--color-background);
    border: 0;
    font-size: 14px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    cursor: pointer;
  }

  .sell-form__submit:hover {
    opacity: 0.85;
  }

  .sell-form__submit[disabled] {
    opacity: 0.5;
    cursor: default;
  }

  .sell-form__note {
    margin: 20px 0 0;
    text-align: center;
    color: rgb(var(--color-foreground-rgb) / 0.55);
    font-size: 14px;
  }

  .sell-form__success-title {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: var(--font-h3--size, 2rem);
    margin: 0 0 20px;
  }

  .sell-form__success-check {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #2e9e44;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .sell-form__success-text {
    line-height: 1.6;
    margin: 0 0 32px;
  }

  .sell-form__success-text a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .sell-form__reset {
    margin-top: 0;
  }

  @media screen and (max-width: 749px) {
    .sell-form {
      padding-block: 8px 40px;
    }

    .sell-form__dropzone {
      padding: 36px 16px;
    }
  }
{% endstylesheet %}

<script>
  (() => {
    const root = document.currentScript.previousElementSibling ? document.querySelector('.sell-form') : null;
    const form = document.querySelector('.sell-form__form');
    if (!form || form.__bound) return;
    form.__bound = true;

    const dropzone = form.querySelector('[data-dropzone]');
    const fileInput = form.querySelector('[data-file-input]');
    const previews = form.querySelector('[data-previews]');
    const errorEl = form.querySelector('[data-error]');
    const submitBtn = form.querySelector('.sell-form__submit');
    const successEl = document.querySelector('[data-success]');

    const MAX_FILES = 10;
    const MAX_SOURCE_BYTES = 30 * 1024 * 1024; // per original file
    let items = []; // { file, blob, url }

    function showError(msg) {
      errorEl.textContent = msg;
      errorEl.hidden = !msg;
    }

    const REQUIRED = [
      ['sell-name', 'Fyll i ditt namn.'],
      ['sell-email', 'Fyll i en giltig e-postadress.'],
      ['sell-phone', 'Fyll i ditt telefonnummer.'],
      ['sell-model', 'Fyll i märke och modell.'],
    ];

    function setFieldError(el, err, bad) {
      err.hidden = !bad;
      el.classList.toggle('sell-form__input--invalid', bad);
      el.setAttribute('aria-invalid', bad ? 'true' : 'false');
    }

    function validateFields() {
      let firstBad = null;
      REQUIRED.forEach(([id, msg]) => {
        const el = document.getElementById(id);
        const err = document.getElementById('err-' + id);
        if (!el || !err) return;
        let bad = !el.value.trim();
        if (id === 'sell-email' && !bad) bad = !el.checkValidity();
        err.textContent = msg;
        setFieldError(el, err, bad);
        if (bad && !firstBad) firstBad = el;
      });
      if (firstBad) {
        firstBad.scrollIntoView({ block: 'center', behavior: 'smooth' });
        firstBad.focus({ preventScroll: true });
        return false;
      }
      return true;
    }

    // Clear a field's error as soon as the user fixes it
    REQUIRED.forEach(([id]) => {
      const el = document.getElementById(id);
      const err = document.getElementById('err-' + id);
      if (!el || !err) return;
      el.addEventListener('input', () => {
        if (el.value.trim()) setFieldError(el, err, false);
      });
    });

    function formatBytes(b) {
      if (b < 1024 * 1024) return Math.max(1, Math.round(b / 1024)) + ' KB';
      return (b / 1048576).toFixed(1).replace('.', ',') + ' MB';
    }

    // Downscale to max 1600px JPEG so phone photos upload fast and the email
    // stays under the size cap. Falls back to the original file if the image
    // can't be decoded (e.g. odd formats).
    async function compress(file) {
      try {
        const bitmap = await createImageBitmap(file);
        const scale = Math.min(1, 1600 / Math.max(bitmap.width, bitmap.height));
        if (scale === 1 && file.size < 800 * 1024 && file.type === 'image/jpeg') return file;
        const canvas = document.createElement('canvas');
        canvas.width = Math.round(bitmap.width * scale);
        canvas.height = Math.round(bitmap.height * scale);
        canvas.getContext('2d').drawImage(bitmap, 0, 0, canvas.width, canvas.height);
        bitmap.close();
        const blob = await new Promise((res) => canvas.toBlob(res, 'image/jpeg', 0.82));
        return blob || file;
      } catch {
        return file;
      }
    }

    async function addFiles(fileList) {
      showError('');
      for (const file of fileList) {
        if (items.length >= MAX_FILES) {
          showError('Max ' + MAX_FILES + ' bilder.');
          break;
        }
        if (!file.type.startsWith('image/')) {
          showError('Endast bildfiler kan laddas upp.');
          continue;
        }
        if (file.size > MAX_SOURCE_BYTES) {
          showError('En bild är för stor (max 30 MB).');
          continue;
        }
        const blob = await compress(file);
        const url = URL.createObjectURL(blob);
        items.push({ file, blob, url });
        const li = document.createElement('li');
        const img = document.createElement('img');
        img.src = url;
        img.alt = '';
        const meta = document.createElement('div');
        meta.className = 'sell-form__preview-meta';
        const nameEl = document.createElement('span');
        nameEl.className = 'sell-form__preview-name';
        nameEl.textContent = file.name || 'bild.jpg';
        const sizeEl = document.createElement('span');
        sizeEl.className = 'sell-form__preview-size';
        sizeEl.textContent = formatBytes(blob.size);
        meta.append(nameEl, sizeEl);
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.setAttribute('aria-label', 'Ta bort ' + (file.name || 'bild'));
        btn.innerHTML =
          '<svg viewBox="0 0 14 14" width="14" height="14" fill="none" aria-hidden="true">' +
          '<path d="M1.5 1.5l11 11M12.5 1.5l-11 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>';
        btn.addEventListener('click', () => {
          const i = [...previews.children].indexOf(li);
          if (i > -1) {
            URL.revokeObjectURL(items[i].url);
            items.splice(i, 1);
          }
          li.remove();
        });
        li.append(img, meta, btn);
        previews.appendChild(li);
      }
    }

    dropzone.addEventListener('click', () => fileInput.click());
    dropzone.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        fileInput.click();
      }
    });
    fileInput.addEventListener('change', () => {
      addFiles([...fileInput.files]);
      fileInput.value = '';
    });
    ['dragover', 'dragenter'].forEach((t) =>
      dropzone.addEventListener(t, (e) => {
        e.preventDefault();
        dropzone.classList.add('is-dragover');
      })
    );
    ['dragleave', 'drop'].forEach((t) =>
      dropzone.addEventListener(t, (e) => {
        e.preventDefault();
        dropzone.classList.remove('is-dragover');
      })
    );
    dropzone.addEventListener('drop', (e) => {
      if (e.dataTransfer && e.dataTransfer.files.length) addFiles([...e.dataTransfer.files]);
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      showError('');

      const endpoint = form.dataset.endpoint;
      if (!endpoint) {
        showError('Formuläret är inte aktiverat ännu. Ring oss på 031-711 03 09 eller mejla order@mug.se.');
        return;
      }
      if (!validateFields()) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Skickar…';

      try {
        const fd = new FormData();
        ['company', 'name', 'email', 'phone', 'model', 'description'].forEach((n) => {
          fd.append(n, form.elements[n] ? form.elements[n].value : '');
        });
        items.forEach((it, i) => {
          const base = (it.file.name || 'bild').replace(/\.[a-z0-9]+$/i, '');
          fd.append('images', it.blob, base + '.jpg');
        });

        const res = await fetch(endpoint, { method: 'POST', body: fd });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data.ok) throw new Error(data.error || 'send-failed');

        form.hidden = true;
        // Per design, the success view replaces the whole intro too
        document.querySelector('.sell-form__title')?.setAttribute('hidden', '');
        document.querySelector('.sell-form__intro')?.setAttribute('hidden', '');
        successEl.hidden = false;
        successEl.scrollIntoView({ block: 'center', behavior: 'smooth' });
        const resetBtn = successEl.querySelector('[data-reset]');
        if (resetBtn && !resetBtn.__bound) {
          resetBtn.__bound = true;
          resetBtn.addEventListener('click', () => location.reload());
        }
      } catch (err) {
        showError('Något gick fel när formuläret skickades. Försök igen, eller mejla oss direkt på order@mug.se.');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Skicka bilder';
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Sälj/byt in-formulär",
  "settings": [
    {
      "type": "text",
      "id": "endpoint",
      "label": "Endpoint URL",
      "info": "Cloudflare Worker-adressen som tar emot formuläret (se scripts/sell-form-worker/README.md). Lämnas den tom visar formuläret ett felmeddelande vid skick."
    },
    {
      "type": "url",
      "id": "back_url",
      "label": "Tillbaka-länk"
    }
  ],
  "presets": []
}
{% endschema %}
