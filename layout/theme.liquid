<!doctype html>
<html
  class="no-js{% if request.design_mode %} shopify-design-mode{% endif %}"
  lang="{{ request.locale.iso_code }}"
>
  <head>
    <link rel="preconnect" href="https://cdn.shopify.com">
  <link rel="preconnect" href="https://cdn.instant.so" crossorigin>
  <link rel="dns-prefetch" href="https://www.googletagmanager.com">
  <link rel="dns-prefetch" href="https://cdn.boostcommerce.io">

  {%- render 'stylesheets' -%}

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% # theme-check-disable RemoteAsset %}
    <link
      rel="expect"
      href="#MainContent"
      blocking="render"
      id="view-transition-render-blocker"
    >
    {% # theme-check-enable RemoteAsset %}

    {%- render 'meta-tags' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}

    <style>
      /* ── Thumbnail border fix ── */
      .slideshow-controls__thumbnails-container {
        padding: 0 !important;
      }

      .slideshow-controls__thumbnails {
        padding: 0px !important;
    gap: 0px !important;
    padding: 0px !important;
      }

      .slideshow-controls__thumbnail {
        padding: 0 !important;
        overflow: hidden !important;
        border: 1px solid #dcdcdc !important;
        box-shadow: none !important;
        outline: none !important;
      }

      .slideshow-controls__thumbnail[aria-selected="true"] {
        border: 1px solid rgba(0, 0, 0, 0.81) !important;
        box-shadow: none !important;
        outline: none !important;

      }

      .slideshow-controls__thumbnail img {
        display: block !important;
        width: 100% !important;
        height: 100% !important;
        object-fit: cover !important;
      }
    </style>
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }} template-{{ template | split: '.' | first }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script
      src="{{ 'critical.js' | asset_url }}"
      type="module"
      async
      blocking="render"
    ></script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}

    <script>
document.addEventListener("DOMContentLoaded", function() {
  // Watch for any product video elements
  const mediaWrappers = document.querySelectorAll('deferred-media, .product__media video');

  mediaWrappers.forEach(wrapper => {
    let video = wrapper.querySelector('video');
    
    if (video) {
      // When user clicks play button or the video itself
      video.addEventListener('play', () => {
        // Unmute and enable sound
        video.muted = false;
        video.volume = 1.0;
      });

      // Some Shopify videos use a custom play overlay button
      const playButton = wrapper.querySelector('button, .deferred-media__poster');
      if (playButton) {
        playButton.addEventListener('click', () => {
          setTimeout(() => {
            video.muted = false;
            video.volume = 1.0;
            video.play().catch(()=>{});
          }, 200);
        });
      }
    }
  });
});

</script>

<script>
// ── Filter loading shimmer ──
(function () {
  document.addEventListener('filter:update', function () {
    var grid = document.querySelector('results-list');
    if (!grid) return;
    grid.setAttribute('data-loading', '');
    var resolved = false;
    function resolve() {
      if (resolved) return;
      resolved = true;
      grid.removeAttribute('data-loading');
    }
    setTimeout(resolve, 3000);
    requestAnimationFrame(function () {
      var mo = new MutationObserver(function () {
        if (grid.querySelector('.product-grid__item')) {
          resolve();
          mo.disconnect();
        }
      });
      mo.observe(grid, { childList: true, subtree: true });
    });
  });
})();

// ── LQIP blur-up ──
(function () {
  function initLQIP(root) {
    (root || document).querySelectorAll('.product-media__image--lqip:not(.is-loaded)').forEach(function (img) {
      function onLoad() { img.classList.add('is-loaded'); }
      // Use naturalWidth as the primary signal — it is 0 until the image is
      // actually decoded and ready, unlike img.complete which iOS Safari sets
      // to true immediately on lazy images before the fetch even starts.
      if (img.naturalWidth > 0) {
        onLoad();
      } else {
        img.addEventListener('load', onLoad, { once: true });
        img.addEventListener('error', onLoad, { once: true });
      }
    });
  }
  // ── iOS Safari: force lazy images to actually fetch ──
  // On iOS Safari, images parsed from HTML with loading="lazy" sometimes never
  // fetch from the network at all — not just a missing load event but a genuine
  // non-fetch. Dynamically-inserted images (e.g. "Visa mer") work because the
  // browser ignores the lazy attribute on JS-injected elements.
  // Fix: detect iOS Safari, strip the loading attribute, then reset src/srcset.
  // Resetting the attributes restarts the browser's image-loading algorithm,
  // this time without lazy deferral, mirroring what JS injection achieves.
  (function () {
    var ua = navigator.userAgent;
    var isIOSSafari = /iP(hone|ad|od)/i.test(ua) &&
                      /Safari/i.test(ua) &&
                      !/CriOS|FxiOS|EdgiOS/i.test(ua);
    if (!isIOSSafari) return;
    function forceLoadImages(root) {
      (root || document).querySelectorAll('.product-media__image--lqip[loading="lazy"]').forEach(function (img) {
        if (img.naturalWidth > 0) return; // already decoded, skip
        img.removeAttribute('loading');
        // Reset src/srcset so the browser restarts the load without lazy deferral
        ['srcset', 'src'].forEach(function (attr) {
          var val = img.getAttribute(attr);
          if (val) { img.removeAttribute(attr); img.setAttribute(attr, val); }
        });
      });
    }
    document.addEventListener('DOMContentLoaded', function () { forceLoadImages(document); });
    // Also handle images added later (infinite scroll, quick-view, etc.)
    new MutationObserver(function (mutations) {
      mutations.forEach(function (m) {
        m.addedNodes.forEach(function (node) {
          if (node.nodeType === 1) forceLoadImages(node);
        });
      });
    }).observe(document.documentElement, { childList: true, subtree: true });
  })();

  document.addEventListener('DOMContentLoaded', function () { initLQIP(document); });
  // window.load fires after all page resources. Force-reveal anything still
  // hidden at that point — catches the iOS Safari lazy-loading bug where
  // complete=true but the load event never fires.
  window.addEventListener('load', function () {
    initLQIP(document);
    document.querySelectorAll('.product-media__image--lqip:not(.is-loaded)').forEach(function (img) {
      img.classList.add('is-loaded');
    });
  });
  // Poll every 500 ms for images that loaded without firing events.
  // naturalWidth becomes non-zero as soon as the browser decodes the image.
  // Stop after 12 s to avoid running forever on slow connections.
  (function () {
    var deadline = Date.now() + 12000;
    var timer = setInterval(function () {
      var pending = false;
      document.querySelectorAll('.product-media__image--lqip:not(.is-loaded)').forEach(function (img) {
        if (img.naturalWidth > 0) {
          img.classList.add('is-loaded');
        } else {
          pending = true;
        }
      });
      if (!pending || Date.now() > deadline) clearInterval(timer);
    }, 500);
  })();
  new MutationObserver(function (mutations) {
    mutations.forEach(function (m) {
      m.addedNodes.forEach(function (node) {
        if (node.nodeType === 1) initLQIP(node);
      });
    });
  }).observe(document.body, { childList: true, subtree: true });
})();
</script>

<script>
(function () {
  function labelAllaLinks() {
    var links = document.querySelectorAll('.tmenu_submenu--desktop .tmenu_item_link:not(.tmenu-alla-link)');
    links.forEach(function (link) {
      if (link.textContent.trim().startsWith('Alla')) {
        link.classList.add('tmenu-alla-link');
      }
    });
  }
  var observer = new MutationObserver(labelAllaLinks);
  observer.observe(document.documentElement, { childList: true, subtree: true });
})();
</script>

{% if template contains 'collection' %}
<style>
  /*
    Pre-collapse the collection description immediately so it never flashes
    at full height before the desc-expand JS initialises. The :not selector
    drops away as soon as JS sets data-clamp-init, which happens within the
    same synchronous call that inserts the wrapper — so the browser never
    paints an uncollapsed in-between state.
    4.5em = 3 lines at line-height: 1.5 (scales correctly with font-size).
  */
  rte-formatter[class*="text_twGGkJ"]:not([data-clamp-init]) {
    max-height: 4.5em;
    overflow: hidden;
  }
</style>
<script>
(function() {
  function initDescExpand() {
    var block = document.querySelector('rte-formatter[class*="text_twGGkJ"]');
    if (!block || block.dataset.clampInit) return false;

    var ref = block.querySelector('p') || block;
    var lh = parseFloat(window.getComputedStyle(ref).lineHeight);
    if (!lh || isNaN(lh)) return false;
    var maxH = Math.round(lh) * 3;

    if (block.scrollHeight <= maxH + 4) return true; // fits, no clamp needed

    block.dataset.clampInit = '1';

    // Wrap block's children in a plain div so position:relative works reliably
    var wrapper = document.createElement('div');
    wrapper.className = 'desc-read-more-wrapper';
    wrapper.style.maxHeight = maxH + 'px';
    wrapper.style.overflow = 'hidden';
    wrapper.style.position = 'relative';
    while (block.firstChild) {
      wrapper.appendChild(block.firstChild);
    }
    block.appendChild(wrapper);

    var overlay = document.createElement('span');
    overlay.className = 'desc-read-more-overlay';
    var link = document.createElement('a');
    link.href = '#';
    link.textContent = 'Läs mer';
    link.className = 'desc-read-more-btn';
    overlay.appendChild(link);
    link.addEventListener('click', function(e) {
      e.preventDefault();
      // Animate max-height from the current clamped pixel value to the
      // full scrollHeight. CSS transitions can't go from a px value to
      // `auto`/empty, so we set an explicit target then clean up once
      // the transition finishes.
      var fullHeight = wrapper.scrollHeight;
      wrapper.style.maxHeight = wrapper.offsetHeight + 'px';
      // Force reflow so the browser registers the starting value before
      // we change to the target value, otherwise the transition skips.
      void wrapper.offsetHeight;
      overlay.classList.add('is-fading');
      // Trigger mask-image transition: the bottom fade mask slides off
      // so the previously-faded last line fades IN smoothly.
      wrapper.classList.add('is-expanded');
      wrapper.style.maxHeight = fullHeight + 'px';
      wrapper.addEventListener('transitionend', function onEnd(ev) {
        if (ev.propertyName !== 'max-height') return;
        wrapper.style.maxHeight = '';
        wrapper.style.overflow = '';
        wrapper.style.position = '';
        overlay.remove();
      }, { once: true });
    });
    // Append overlay to block (after wrapper) so "Läs mer" appears as a
    // normal flow element below the truncated text rather than floating
    // over the last visible line inside the overflow:hidden wrapper.
    block.appendChild(overlay);
    return true;
  }

  var mo = new MutationObserver(function() {
    if (initDescExpand()) mo.disconnect();
  });
  mo.observe(document.documentElement, { childList: true, subtree: true });
  if (!initDescExpand()) {
    [200, 600, 1200].forEach(function(d) {
      setTimeout(function() { if (initDescExpand()) mo.disconnect(); }, d);
    });
  }
})();
</script>
{% endif %}

  </body>
</html>