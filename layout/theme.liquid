<!doctype html>
<html
  class="no-js{% if request.design_mode %} shopify-design-mode{% endif %}"
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- render 'stylesheets' -%}

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% # theme-check-disable RemoteAsset %}
    <link
      rel="expect"
      href="#MainContent"
      blocking="render"
      id="view-transition-render-blocker"
    >
    {% # theme-check-enable RemoteAsset %}

    {%- render 'meta-tags' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}

    <style>
      /* ── Finns i butik — toggle switch ── */

      /* Hide the dropdown panel */
      #facet-inputs-filter-p-m-inventory-butik {
        display: none !important;
      }

      /* Summary row layout */
      details[id*="filter-p-m-inventory-butik"] > summary {
        display: flex !important;
        align-items: center !important;
        gap: 10px !important;
        cursor: pointer !important;
        list-style: none !important;
        position: relative !important;
        padding-left: 40px !important;
      }

      /* Hide the caret */
      details[id*="filter-p-m-inventory-butik"] > summary .icon-caret {
       
      }

      /* Label text — match checkbox labels exactly */
      details[id*="filter-p-m-inventory-butik"] > summary .facets__label {
        order: 1 !important;
        font-size: 14px !important;
        font-weight: 400 !important;
        font-family: "Inter Variable", sans-serif !important;
        text-transform: none !important;
        letter-spacing: normal !important;
      }

      /* Hide the status wrapper — we inject count via JS instead */
      details[id*="filter-p-m-inventory-butik"] > summary .facets__status-wrapper {
        display: none !important;
      }

      /* Injected count — match .filter-product-count styling */
      details[id*="filter-p-m-inventory-butik"] > summary .facets__butik-count {
        margin-left: auto !important;
        opacity: 0.7 !important;
        font-size: 14px !important;
        font-weight: 400 !important;
        font-family: "Inter Variable", sans-serif !important;
      }

      /* Toggle track */
      details[id*="filter-p-m-inventory-butik"] > summary::before {
        content: '' !important;
        position: absolute !important;
        left: 0 !important;
        top: 50% !important;
        transform: translateY(-50%) !important;
        width: 32px !important;
        height: 18px !important;
        background-color: #ccc !important;
        border-radius: 999px !important;
        transition: background-color 0.2s ease !important;
      }

      /* Thumb */
      details[id*="filter-p-m-inventory-butik"] > summary .facets__label::before {
        content: '' !important;
        position: absolute !important;
        left: 2px !important;
        top: 50% !important;
        transform: translateY(-50%) !important;
        width: 14px !important;
        height: 14px !important;
        background: #fff !important;
        border-radius: 50% !important;
        box-shadow: 0 1px 2px rgba(0,0,0,0.2) !important;
        transition: transform 0.2s ease !important;
      }

      /* Checked — green track */
      details[id*="filter-p-m-inventory-butik"]:has(input:checked) > summary::before {
        background-color: #2a9d4e !important;
      }

      /* Checked — thumb slides right */
      details[id*="filter-p-m-inventory-butik"]:has(input:checked) > summary .facets__label::before {
        transform: translateY(-50%) translateX(14px) !important;
      }

      /* ── Thumbnail border fix ── */
      .slideshow-controls__thumbnails-container {
        padding: 0 !important;
      }

      .slideshow-controls__thumbnails {
        padding: 0px !important;
    gap: 0px !important;
    padding: 0px !important;
      }

      .slideshow-controls__thumbnail {
        padding: 0 !important;
        overflow: hidden !important;
        border: 1px solid #dcdcdc !important;
        box-shadow: none !important;
        outline: none !important;
      }

      .slideshow-controls__thumbnail[aria-selected="true"] {
        border: 1px solid rgba(0, 0, 0, 0.81) !important;
        box-shadow: none !important;
        outline: none !important;

      }

      .slideshow-controls__thumbnail img {
        display: block !important;
        width: 100% !important;
        height: 100% !important;
        object-fit: cover !important;
      }
    </style>
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script
      src="{{ 'critical.js' | asset_url }}"
      type="module"
      async
      blocking="render"
    ></script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}

    <script>
document.addEventListener("DOMContentLoaded", function() {
  // Watch for any product video elements
  const mediaWrappers = document.querySelectorAll('deferred-media, .product__media video');

  mediaWrappers.forEach(wrapper => {
    let video = wrapper.querySelector('video');
    
    if (video) {
      // When user clicks play button or the video itself
      video.addEventListener('play', () => {
        // Unmute and enable sound
        video.muted = false;
        video.volume = 1.0;
      });

      // Some Shopify videos use a custom play overlay button
      const playButton = wrapper.querySelector('button, .deferred-media__poster');
      if (playButton) {
        playButton.addEventListener('click', () => {
          setTimeout(() => {
            video.muted = false;
            video.volume = 1.0;
            video.play().catch(()=>{});
          }, 200);
        });
      }
    }
  });
});

// ── Finns i butik — wire summary click to checkbox + show count ──
function initButikToggle() {
  document.querySelectorAll('facet-inputs-component').forEach(el => {
    const input = el.querySelector('input[name="filter.p.m.inventory.butik"]');
    if (!input) return;

    const countEl = el.querySelector('.filter-product-count');
    const details = input.closest('details[id*="filter-p-m-inventory-butik"]');
    if (!details) return;

    const summary = details.querySelector('summary');
    if (!summary) return;

    // Inject count if not already done
    if (!summary.querySelector('.facets__butik-count') && countEl) {
      const countSpan = document.createElement('span');
      countSpan.className = 'facets__butik-count';
      countSpan.textContent = countEl.textContent.trim();
      summary.appendChild(countSpan);
    }
  });
}

// Run on load
document.addEventListener('DOMContentLoaded', initButikToggle);

// Watch for dynamic rendering
const butikObserver = new MutationObserver(function() {
  initButikToggle();
});
butikObserver.observe(document.body, { childList: true, subtree: true });

// Click handler
document.addEventListener('click', function (e) {
  const summary = e.target.closest('details[id*="filter-p-m-inventory-butik"] > summary');
  if (summary) {
    e.preventDefault();
    e.stopPropagation();
    const checkbox = summary.closest('details').querySelector('input[name="filter.p.m.inventory.butik"]');
    if (checkbox) {
      checkbox.checked = !checkbox.checked;
      checkbox.dispatchEvent(new Event('change', { bubbles: true }));
    }
  }
});
</script>

  </body>
</html>