<!doctype html>
<html
  class="no-js{% if request.design_mode %} shopify-design-mode{% endif %}"
  lang="{{ request.locale.iso_code }}"
>
  <head>
 {%- if content_for_header contains 'tapita-seo-script-tags' -%}{%- include 'tapita-seo-schema' -%}{%- endif -%} 

    <link rel="preconnect" href="https://cdn.shopify.com">
  <link rel="preconnect" href="https://cdn.instant.so" crossorigin>
  <link rel="preconnect" href="https://www.googletagmanager.com">
  <link rel="dns-prefetch" href="https://www.googletagmanager.com">
  <link rel="preconnect" href="https://cdn.boostcommerce.io" crossorigin>
  <link rel="dns-prefetch" href="https://cdn.boostcommerce.io">

  {%- render 'stylesheets' -%}

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} View-transition render blocker removed — view transitions are
      disabled (navigation:none in custom.css) so blocking="render" only adds
      latency without benefit. {% endcomment %}

    {% comment %} Speculation Rules: prerender product pages on hover so navigation
      feels near-instant. Moderate eagerness = triggers ~200ms after hover, not on
      every link entering the viewport. Excludes cart/checkout/account to avoid
      side-effects. Gracefully ignored by Safari/Firefox. {% endcomment %}
    <script type="speculationrules">
    {
      "prerender": [
        {
          "where": {
            "and": [
              { "href_matches": "/products/*" },
              { "not": { "href_matches": "/*\\?*add*" } }
            ]
          },
          "eagerness": "moderate"
        }
      ],
      "prefetch": [
        {
          "where": {
            "and": [
              { "href_matches": "/collections/*" },
              { "not": { "href_matches": "/*\\?*add*" } }
            ]
          },
          "eagerness": "moderate"
        }
      ]
    }
    </script>

    {%- render 'meta-tags' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}

    {% if template contains 'collection' %}
    <style>
      /*
        Collection description clamp — pure CSS so the block has its final
        height from the very first paint and never changes during load.
        JS (end of body) only adds the "Läs mer" overlay link when the text
        actually overflows; clicking it adds .desc-expanded. Because the
        clamp itself is CSS, a late or re-run script can never cause the
        height to jump.
      */
      rte-formatter[class*="text_twGGkJ"] {
        position: relative;
      }
      /* Block + max-height clamp (no -webkit-line-clamp). The max-height in
         lh caps the box at exactly three line boxes regardless of
         font-size/line-height at any viewport — the 4.2em before it is only
         a fallback for browsers without the lh unit — so the height is
         stable from the first paint. The JS below trims the visible text to
         fit and drops the "Läs mer" link inline right after the truncation. */
      rte-formatter[class*="text_twGGkJ"]:not(.desc-expanded) {
        display: block !important;
        max-height: 4.2em !important;
        max-height: 3lh !important;
        overflow: hidden !important;
      }
      /* Inline link sitting right after the trimmed text. left:auto/static
         guard against a global rule that stretches links across the block. */
      .desc-read-more-btn {
        position: static !important;
        left: auto !important;
        right: auto !important;
        width: auto !important;
        display: inline !important;
        color: inherit;
        text-decoration: underline;
        text-underline-offset: 2px;
        white-space: nowrap;
        cursor: pointer;
      }
      /* Ellipsis marking the truncation — a plain text span before the link,
         so the dots are neither underlined nor clickable. */
      .desc-ellipsis {
        text-decoration: none;
        cursor: text;
      }
    </style>
    {% endif %}

    <style>
      /* ── Thumbnail border fix ── */
      .slideshow-controls__thumbnails-container {
        padding: 0 !important;
      }

      .slideshow-controls__thumbnails {
        padding: 0px !important;
        gap: 0px !important;
      }

      .slideshow-controls__thumbnail {
        padding: 0 !important;
        overflow: hidden !important;
        border: 1px solid #dcdcdc !important;
        box-shadow: none !important;
        outline: none !important;
      }

      .slideshow-controls__thumbnail[aria-selected="true"] {
        border: 1px solid rgba(0, 0, 0, 0.81) !important;
        box-shadow: none !important;
        outline: none !important;

      }

      .slideshow-controls__thumbnail img {
        display: block !important;
        width: 100% !important;
        height: 100% !important;
        object-fit: cover !important;
      }
    </style>
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }} template-{{ template | split: '.' | first }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script
      src="{{ 'critical.js' | asset_url }}"
      type="module"
      async
    ></script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {% if template == 'index' %}
        <h1 class="visually-hidden">{{ shop.name }}</h1>
      {% endif %}
      {{ content_for_layout }}
    </main>

    {%- comment -%} Policy pages (/policies/*) can only use a .liquid template and
      can't render section groups themselves, so the shared "image grid above the
      footer" group is injected here for them (matches the other static pages). {%- endcomment -%}
    {%- if template == 'policy' -%}
      {% sections 'store-grid-group' %}
    {%- endif -%}

    {% sections 'footer-group' %}

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "MusicStore",
      "name": {{ shop.name | json }},
      "description": {{ shop.description | json }},
      "url": {{ request.origin | json }},
      {% if shop.phone != blank %}
        "telephone": {{ shop.phone | json }},
      {% endif %}
      {% if shop.email != blank %}
        "email": {{ shop.email | json }},
      {% endif %}
      {% if shop.address %}
        "address": {
          "@type": "PostalAddress",
          "streetAddress": {{ shop.address.address1 | json }},
          "addressLocality": {{ shop.address.city | json }},
          "postalCode": {{ shop.address.zip | json }},
          "addressCountry": {{ shop.address.country_code | json }}
        },
      {% endif %}
      {% if settings.logo %}
        "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
        "image": {{ settings.logo | image_url: width: 1200 | prepend: "https:" | json }},
      {% endif %}
      "sameAs": [
        {{ request.origin | json }}
      ]
    }
    </script>

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}

    <script>
document.addEventListener("DOMContentLoaded", function() {
  // Watch for any product video elements
  const mediaWrappers = document.querySelectorAll('deferred-media, .product__media video');

  mediaWrappers.forEach(wrapper => {
    let video = wrapper.querySelector('video');
    
    if (video) {
      // When user clicks play button or the video itself
      video.addEventListener('play', () => {
        // Unmute and enable sound
        video.muted = false;
        video.volume = 1.0;
      });

      // Some Shopify videos use a custom play overlay button
      const playButton = wrapper.querySelector('button, .deferred-media__poster');
      if (playButton) {
        playButton.addEventListener('click', () => {
          setTimeout(() => {
            video.muted = false;
            video.volume = 1.0;
            video.play().catch(()=>{});
          }, 200);
        });
      }
    }
  });
});

</script>

<script>
// ── Filter loading shimmer ──
(function () {
  document.addEventListener('filter:update', function () {
    var grid = document.querySelector('results-list');
    if (!grid) return;
    grid.setAttribute('data-loading', '');
    var resolved = false;
    function resolve() {
      if (resolved) return;
      resolved = true;
      grid.removeAttribute('data-loading');
    }
    setTimeout(resolve, 3000);
    requestAnimationFrame(function () {
      var mo = new MutationObserver(function () {
        if (grid.querySelector('.product-grid__item')) {
          resolve();
          mo.disconnect();
        }
      });
      mo.observe(grid, { childList: true, subtree: true });
    });
  });
})();

// ── LQIP blur-up ──
(function () {
  function initLQIP(root) {
    (root || document).querySelectorAll('.product-media__image--lqip:not(.is-loaded)').forEach(function (img) {
      function onLoad() { img.classList.add('is-loaded'); }
      // Use naturalWidth as the primary signal — it is 0 until the image is
      // actually decoded and ready, unlike img.complete which iOS Safari sets
      // to true immediately on lazy images before the fetch even starts.
      if (img.naturalWidth > 0) {
        onLoad();
      } else {
        img.addEventListener('load', onLoad, { once: true });
        img.addEventListener('error', onLoad, { once: true });
      }
    });
  }
  // ── iOS Safari: use img.decode() to force-initiate image loading ──
  // "Visa mer" (infinite scroll) images work because grid.append() with
  // DOMParser elements bypasses loading="lazy" — the browser eagerly loads
  // dynamically-inserted images. Initial page images don't benefit from this.
  // img.decode() is the standard API for explicitly initiating image loading
  // and decoding. On iOS Safari it bypasses lazy-loading deferral and fires
  // even when the load event is silently suppressed.
  (function () {
    var ua = navigator.userAgent;
    var isIOSSafari = /iP(hone|ad|od)/i.test(ua) &&
                      /Safari/i.test(ua) &&
                      !/CriOS|FxiOS|EdgiOS/i.test(ua);
    if (!isIOSSafari) return;
    function decodeImages(root) {
      (root || document).querySelectorAll('.product-media__image--lqip').forEach(function (img) {
        if (img.naturalWidth > 0) {
          img.classList.add('is-loaded');
          return;
        }
        img.decode().then(function () {
          img.classList.add('is-loaded');
        }).catch(function () {
          // decode() rejected means image failed or was aborted —
          // still reveal so the card doesn't stay blank.
          img.classList.add('is-loaded');
        });
      });
    }
    document.addEventListener('DOMContentLoaded', function () { decodeImages(document); });
    // Handle images added later by infinite scroll / quick-view
    new MutationObserver(function (mutations) {
      mutations.forEach(function (m) {
        m.addedNodes.forEach(function (node) {
          if (node.nodeType === 1) decodeImages(node);
        });
      });
    }).observe(document.documentElement, { childList: true, subtree: true });
  })();

  document.addEventListener('DOMContentLoaded', function () { initLQIP(document); });
  // window.load fires after all page resources. Force-reveal anything still
  // hidden at that point — catches the iOS Safari lazy-loading bug where
  // complete=true but the load event never fires.
  window.addEventListener('load', function () {
    initLQIP(document);
    document.querySelectorAll('.product-media__image--lqip:not(.is-loaded)').forEach(function (img) {
      img.classList.add('is-loaded');
    });
  });
  // Poll every 500 ms for images that loaded without firing events.
  // naturalWidth becomes non-zero as soon as the browser decodes the image.
  // Stop after 12 s to avoid running forever on slow connections.
  (function () {
    var deadline = Date.now() + 12000;
    var timer = setInterval(function () {
      var pending = false;
      document.querySelectorAll('.product-media__image--lqip:not(.is-loaded)').forEach(function (img) {
        if (img.naturalWidth > 0) {
          img.classList.add('is-loaded');
        } else {
          pending = true;
        }
      });
      if (!pending || Date.now() > deadline) clearInterval(timer);
    }, 500);
  })();
  // Handle newly added nodes (infinite scroll) AND srcset attribute changes
  // (morph after filter).  When morph patches an existing image element in
  // place the childList observer never fires — only an attributes observer
  // on srcset detects the change.  Re-running initLQIP on the parent
  // re-attaches the load listener so is-loaded is added the moment the new
  // product image arrives, ending the blurry LQIP state as quickly as
  // possible.
  new MutationObserver(function (mutations) {
    mutations.forEach(function (m) {
      if (m.type === 'attributes') {
        // srcset changed on an img (morph replaced the product image)
        initLQIP(m.target.parentElement || document.body);
      } else {
        m.addedNodes.forEach(function (node) {
          if (node.nodeType === 1) initLQIP(node);
        });
      }
    });
  }).observe(document.body, { childList: true, subtree: true, attributes: true, attributeFilter: ['srcset'] });

  // After a filter update, morph may also reset is-loaded on same-product
  // images whose srcset is unchanged (so the observer above doesn't fire).
  // Run a 5-second fast polling burst to re-add is-loaded to any image
  // whose naturalWidth is already > 0 (already decoded, just had its class
  // stripped by morph).
  document.addEventListener('filter:update', function () {
    initLQIP(document);
    var burstStart = Date.now();
    var burst = setInterval(function () {
      document.querySelectorAll('.product-media__image--lqip:not(.is-loaded)').forEach(function (img) {
        if (img.naturalWidth > 0) img.classList.add('is-loaded');
      });
      if (Date.now() - burstStart > 5000) clearInterval(burst);
    }, 100);
  });
})();
</script>

<script>
(function () {
  function labelAllaLinks() {
    var links = document.querySelectorAll('.tmenu_submenu--desktop .tmenu_item_link:not(.tmenu-alla-link)');
    links.forEach(function (link) {
      if (link.textContent.trim().startsWith('Alla')) {
        link.classList.add('tmenu-alla-link');
      }
    });
  }
  var observer = new MutationObserver(labelAllaLinks);
  observer.observe(document.documentElement, { childList: true, subtree: true });
})();
</script>

<script>
// ── Patch collection links to pre-apply the in-stock filter ──
// Rewrites every <a href="/collections/…"> to include filter.v.availability=1
// so users never trigger the double-load redirect in main-collection.liquid.
// MutationObserver covers links injected after load (Qikify mega menu, etc.).
(function () {
  function patchLinks(root) {
    (root || document).querySelectorAll('a[href*="/collections/"]').forEach(function (a) {
      try {
        var url = new URL(a.href);
        if (url.host !== location.host) return;                      // external links: leave alone
        if (/^\/collections\/?$/.test(url.pathname)) return;         // /collections index: leave alone
        if (url.searchParams.has('filter.v.availability')) return;   // already set: skip
        url.searchParams.set('filter.v.availability', '1');
        a.href = url.toString();
      } catch (e) {}
    });
  }

  document.addEventListener('DOMContentLoaded', function () { patchLinks(document); });

  new MutationObserver(function (mutations) {
    mutations.forEach(function (m) {
      m.addedNodes.forEach(function (node) {
        if (node.nodeType === 1) patchLinks(node);
      });
    });
  }).observe(document.documentElement, { childList: true, subtree: true });
})();
</script>

<script>
  // Menu fallback: the native menu is hidden from first paint (custom.css)
  // so the Qikify mega menu can fade in without a native-menu flash. If
  // Qikify hasn't mounted a few seconds after load (unbound theme, app
  // disabled, script failure), reveal the native menu so the site is never
  // menu-less. The body:has(.tmenu_wrapper) rule re-hides it if Qikify
  // mounts even later.
  (function () {
    function check() {
      if (!document.querySelector('.tmenu_wrapper')) {
        document.body.classList.add('qikify-menu-fallback');
      }
    }
    if (document.readyState === 'complete') {
      setTimeout(check, 3000);
    } else {
      window.addEventListener('load', function () { setTimeout(check, 2500); });
    }
  })();
</script>

{% if template contains 'collection' %}
<script>
(function() {
  // The clamp itself is pure CSS (see <head>): the description paints at its
  // final 3-line height immediately. This script trims the visible text to
  // fit three lines and drops the "Läs mer" link inline right after the
  // truncation point. Height is CSS-stable either way, so running late only
  // swaps text for text within the already-reserved 3-line box.
  function initDescExpand() {
    var block = document.querySelector('rte-formatter[class*="text_twGGkJ"]');
    if (!block) return;
    if (block.classList.contains('desc-expanded')) return;
    if (block.querySelector('.desc-read-more-btn')) return;
    if (block.scrollHeight <= block.clientHeight + 2) return; // fits -- no link

    // Remember the full markup so the link can restore it on expand.
    if (!block.dataset.fullHtml) block.dataset.fullHtml = block.innerHTML;

    var link = document.createElement('a');
    link.href = '#';
    link.className = 'desc-read-more-btn';
    link.textContent = 'Läs mer';
    link.addEventListener('click', function(e) {
      e.preventDefault();
      block.classList.add('desc-expanded');
      block.innerHTML = block.dataset.fullHtml;
    });

    function fits() { return block.scrollHeight <= block.clientHeight + 1; }

    // 1. Drop whole block-level children that begin below the 3-line fold,
    //    plus any empty spacer paragraphs, so the last remaining child is
    //    the one holding the last visible line of text.
    var clampH = block.clientHeight;
    var kids = [].slice.call(block.children);
    var lastVisible = null;
    for (var i = 0; i < kids.length; i++) {
      var rel = kids[i].getBoundingClientRect().top - block.getBoundingClientRect().top;
      if (rel < clampH - 4 && (kids[i].textContent || '').trim() !== '') {
        lastVisible = kids[i];
      }
    }
    if (lastVisible) {
      var strip = false;
      for (var j = 0; j < kids.length; j++) {
        if (kids[j] === lastVisible) { strip = true; continue; }
        if (strip) kids[j].remove();
      }
    }
    // Ellipsis is a separate plain-text span (not inside the link) so the
    // truncation dots are neither underlined nor clickable.
    var ellipsis = document.createElement('span');
    ellipsis.className = 'desc-ellipsis';
    ellipsis.textContent = '… ';

    var host = lastVisible || block;
    host.appendChild(ellipsis);
    host.appendChild(link);

    // 2. Trim trailing words (dropping now-empty inline nodes such as links)
    //    until the text plus the "Läs mer" link fits in the 3-line box.
    var guard = 0;
    while (!fits() && guard++ < 800) {
      var tw = document.createTreeWalker(host, NodeFilter.SHOW_TEXT, null);
      var lastText = null, n;
      while ((n = tw.nextNode())) {
        if (link.contains(n) || ellipsis.contains(n)) continue;
        if (n.nodeValue.trim()) lastText = n;
      }
      if (!lastText) break;
      var trimmed = lastText.nodeValue.replace(/\s*\S+\s*$/, '');
      if (trimmed === lastText.nodeValue) {
        // Nothing left to trim in this node — drop it (or its inline parent).
        var p = lastText.parentNode;
        if (p && p !== host && p !== link && !p.contains(link)) p.remove();
        else lastText.remove();
      } else {
        lastText.nodeValue = trimmed;
      }
    }
  }

  // Run immediately: this script sits at the end of <body>, so the
  // description block already exists. Waiting for DOMContentLoaded made the
  // link appear noticeably after the text (module scripts delay that event).
  initDescExpand();
  // Re-check after full load in case fonts changed the line wrapping or
  // rte-formatter re-rendered its content and dropped the injected link
  // (height is CSS-stable either way).
  window.addEventListener('load', initDescExpand);
})();
</script>
{% endif %}

  </body>
</html>