{%- doc -%}
  Renders a price filter as a dual-thumb range slider.

  @param {object} filter - The filter object to render.
  @param {string} filter_style - The filter style, can be 'horizontal' or 'vertical'.
  @param {boolean} [autofocus] - Whether to autofocus the filter.
  @param {boolean} [should_render_clear] - Whether to render the clear button.
{%- enddoc -%}

{%- liquid
  assign range_max_kr = filter.range_max | divided_by: 100
  assign min_value_kr = 0
  if filter.min_value.value
    assign min_value_kr = filter.min_value.value | divided_by: 100
  endif
  assign max_value_kr = range_max_kr
  if filter.max_value.value
    assign max_value_kr = filter.max_value.value | divided_by: 100
  endif
  assign min_pct = min_value_kr | times: 100 | divided_by: range_max_kr
  assign max_pct = max_value_kr | times: 100 | divided_by: range_max_kr
-%}

<accordion-custom
  class="facets__item"
  {% if filter_style == 'horizontal' %}
    data-disable-animation-on-desktop="true"
    data-close-with-escape="true"
  {% endif %}
  open-by-default-on-mobile
  {% if filter_style == 'vertical' %}
    open
    open-by-default-on-desktop
  {% endif %}
>
  <details
    class="facets__panel"
    {% if filter_style == 'horizontal' %}
      data-auto-close-details="desktop"
    {% endif %}
  >
    <summary class="facets__summary">
      <span class="facets__label">{{ filter.label }}</span>
      <facet-status-component class="facets__status">
        <template ref="moneyFormat">{{ shop.money_format }}</template>
        <span
          class="hide-when-empty"
          ref="facetStatus"
          data-currency="{{ localization.country.currency.iso_code }}"
          data-range-max="{{ filter.range_max }}"
        >
          {%- if filter.min_value.value != null or filter.max_value.value != null %}
            {%- if filter.min_value.value != null and filter.max_value.value != null %}
              {{- filter.min_value.value | money | strip_html -}}–{{- filter.max_value.value | money | strip_html -}}
            {%- elsif filter.min_value.value != null -%}
              {{ filter.min_value.value | money | strip_html }}–{{ filter.range_max | money | strip_html }}
            {%- elsif filter.max_value.value != null -%}
              {{- 0 | money | strip_html -}}–{{- filter.max_value.value | money | strip_html -}}
            {%- endif -%}
          {%- endif -%}
        </span>
      </facet-status-component>
      <span class="svg-wrapper icon-caret icon-animated">
        {{- 'drop-up-svgrepo-com.svg' | inline_asset_content -}}
      </span>
    </summary>

    <floating-panel-component
      {% unless filter_style == 'vertical' %}
        data-close-on-resize
      {% endunless %}
      class="facets__panel-content details-content{% if filter_style == 'horizontal' %} color-{{ settings.popover_color_scheme }}{% endif %}"
    >
      <price-facet-component
        class="price-facet"
        id="facet-inputs-{{ filter.param_name | escape | replace: '.', '-' }}"
        on:change="/updatePriceFilterAndResults"
      >
        {%- comment -%}
          Visually hidden text inputs consumed by PriceFacetComponent (refs + form submission).
          Range sliders sync their values here on every drag; the change event from the
          range inputs then bubbles up to price-facet-component and triggers
          updatePriceFilterAndResults(), which reads these refs and calls updateFilters().
        {%- endcomment -%}
        <input
          class="price-facet__hidden-input"
          type="text"
          name="{{ filter.min_value.param_name }}"
          ref="minInput"
          value="{% if filter.min_value.value %}{{ min_value_kr }}{% endif %}"
          data-min="0"
          data-max="{{ range_max_kr }}"
          autocomplete="off"
          tabindex="-1"
          aria-hidden="true"
          {% if autofocus %}autofocus{% endif %}
        >
        <input
          class="price-facet__hidden-input"
          type="text"
          name="{{ filter.max_value.param_name }}"
          ref="maxInput"
          value="{% if filter.max_value.value %}{{ max_value_kr }}{% endif %}"
          data-min="0"
          data-max="{{ range_max_kr }}"
          autocomplete="off"
          tabindex="-1"
          aria-hidden="true"
        >

        <div
          class="price-slider"
          data-price-slider
          data-range-max="{{ range_max_kr }}"
          data-currency="{{ cart.currency.symbol }}"
          style="--slider-min: {{ min_pct }}%; --slider-max: {{ max_pct }}%"
        >
          <div class="price-slider__track" aria-hidden="true">
            <div class="price-slider__fill"></div>
          </div>
          <input
            type="range"
            class="price-slider__thumb price-slider__thumb--min"
            min="0"
            max="{{ range_max_kr }}"
            value="{{ min_value_kr }}"
            aria-label="{{ filter.label }} minimum"
          >
          <input
            type="range"
            class="price-slider__thumb price-slider__thumb--max"
            min="0"
            max="{{ range_max_kr }}"
            value="{{ max_value_kr }}"
            aria-label="{{ filter.label }} maximum"
          >
        </div>

        <div class="price-slider__values">
          <span class="price-slider__value" data-price-slider-min-label>{{ min_value_kr }} kr</span>
          <span class="price-slider__separator">–</span>
          <span class="price-slider__value" data-price-slider-max-label>{{ max_value_kr }} kr</span>
        </div>

        {%- assign has_active_price = false -%}
        {%- if filter.min_value.value != null or filter.max_value.value != null -%}
          {%- assign has_active_price = true -%}
        {%- endif -%}

        {% if should_render_clear %}
          <facet-clear-component
            class="clear-filter"
            tabindex="{% if has_active_price %}0{% else %}-1{% endif %}"
            on:click="/clearFilter"
            on:keydown="/clearFilter"
          >
            <div
              class="facets__clear {% if has_active_price %}facets__clear--active{% endif %}"
              ref="clearButton"
            >
              {{- 'actions.clear' | t -}}
            </div>
          </facet-clear-component>
        {% endif %}
      </price-facet-component>
    </floating-panel-component>
  </details>
</accordion-custom>

<script>
(function () {
  function getSliderParts(slider) {
    return {
      minThumb: slider.querySelector('.price-slider__thumb--min'),
      maxThumb: slider.querySelector('.price-slider__thumb--max'),
      minLabel: slider.parentElement && slider.parentElement.querySelector('[data-price-slider-min-label]'),
      maxLabel: slider.parentElement && slider.parentElement.querySelector('[data-price-slider-max-label]'),
      minInput: slider.closest('price-facet-component') && slider.closest('price-facet-component').querySelector('[ref="minInput"]'),
      maxInput: slider.closest('price-facet-component') && slider.closest('price-facet-component').querySelector('[ref="maxInput"]'),
      rangeMax: Number(slider.dataset.rangeMax),
      currency: slider.dataset.currency || ''
    };
  }

  function formatKr(value) {
    return value.toLocaleString('sv-SE') + ' kr';
  }

  function updateFill(slider, minVal, maxVal) {
    var max = Number(slider.dataset.rangeMax);
    if (!max) return;
    slider.style.setProperty('--slider-min', (minVal / max * 100) + '%');
    slider.style.setProperty('--slider-max', (maxVal / max * 100) + '%');
  }

  function initSlider(slider) {
    if (slider.__initialized) return;
    slider.__initialized = true;
    var p = getSliderParts(slider);
    if (!p.minThumb || !p.maxThumb) return;
    if (p.minLabel) p.minLabel.textContent = formatKr(Number(p.minThumb.value));
    if (p.maxLabel) p.maxLabel.textContent = formatKr(Number(p.maxThumb.value));
  }

  document.querySelectorAll('[data-price-slider]').forEach(initSlider);

  if (!window.__priceSliderListenerAttached) {
    window.__priceSliderListenerAttached = true;

    document.addEventListener('input', function (e) {
      if (!(e.target instanceof HTMLInputElement) || e.target.type !== 'range') return;
      var slider = e.target.closest('[data-price-slider]');
      if (!slider) return;

      var p = getSliderParts(slider);
      if (!p.minThumb || !p.maxThumb) return;

      var minVal = Number(p.minThumb.value);
      var maxVal = Number(p.maxThumb.value);

      // Prevent thumbs from crossing
      if (e.target === p.minThumb && minVal > maxVal) {
        minVal = maxVal;
        p.minThumb.value = minVal;
      } else if (e.target === p.maxThumb && maxVal < minVal) {
        maxVal = minVal;
        p.maxThumb.value = maxVal;
      }

      // Bring the moved thumb to the front at the crossover point
      p.minThumb.style.zIndex = e.target === p.minThumb ? '4' : '2';
      p.maxThumb.style.zIndex = e.target === p.maxThumb ? '4' : '2';

      updateFill(slider, minVal, maxVal);
      if (p.minLabel) p.minLabel.textContent = formatKr(minVal);
      if (p.maxLabel) p.maxLabel.textContent = formatKr(maxVal);

      // Sync to the hidden text inputs that PriceFacetComponent reads
      if (p.minInput) p.minInput.value = minVal > 0 ? String(minVal) : '';
      if (p.maxInput) p.maxInput.value = maxVal < p.rangeMax ? String(maxVal) : '';
    }, true);

    // The 'change' event from the range input (fired on thumb release) bubbles up
    // to price-facet-component and triggers updatePriceFilterAndResults() automatically
    // via the on:change="/updatePriceFilterAndResults" binding. No additional handling needed.
  }
})();
</script>

{% stylesheet %}
  .price-facet {
    display: flex;
    flex-direction: column;
  }

  /* Visually hidden text inputs — kept in DOM for PriceFacetComponent refs and form submission */
  .price-facet__hidden-input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Slider ── */
  .price-slider {
    position: relative;
    height: 20px; /* thumb diameter — sets the interactive hit area */
    margin: var(--padding-sm) 0 var(--padding-xs);
  }

  /* Track background */
  .price-slider__track {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 4px;
    transform: translateY(-50%);
    background: var(--color-border, #e5e5e5);
    border-radius: 2px;
    pointer-events: none;
  }

  /* Active range fill — positioned via --slider-min / --slider-max custom props */
  .price-slider__fill {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--slider-min, 0%);
    right: calc(100% - var(--slider-max, 100%));
    background: var(--color-foreground, #000);
    border-radius: 2px;
  }

  /* Both range inputs stacked on top of each other */
  .price-slider__thumb {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    background: transparent;
    pointer-events: none; /* track area non-interactive; only the thumb is */
    -webkit-appearance: none;
    appearance: none;
    outline: none;
    z-index: 2;
  }

  .price-slider__thumb:focus-visible::-webkit-slider-thumb {
    outline: 2px solid var(--color-foreground, #000);
    outline-offset: 2px;
  }

  .price-slider__thumb:focus-visible::-moz-range-thumb {
    outline: 2px solid var(--color-foreground, #000);
    outline-offset: 2px;
  }

  /* Remove native track line */
  .price-slider__thumb::-webkit-slider-runnable-track {
    background: transparent;
    border: none;
  }
  .price-slider__thumb::-moz-range-track {
    background: transparent;
    border: none;
  }

  /* Thumb */
  .price-slider__thumb::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-foreground, #000);
    border: 2px solid var(--color-background, #fff);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
    cursor: pointer;
    pointer-events: all;
  }

  .price-slider__thumb::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-foreground, #000);
    border: 2px solid var(--color-background, #fff);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
    cursor: pointer;
    pointer-events: all;
  }

  /* Value labels */
  .price-slider__values {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--padding-xs) 0 var(--padding-sm);
    font-size: var(--font-paragraph--size);
    color: var(--color-foreground);
  }

  .price-slider__separator {
    color: var(--color-foreground-secondary, currentColor);
  }

  .price-facet__highest-price {
    display: none; /* not needed with slider — range is self-evident */
  }
{% endstylesheet %}
