{%- doc -%}
  Outputs the URL for a vendor's brand page: the real collection when one
  exists (they carry meta descriptions and body text), otherwise the
  automatic /collections/vendors page.

  The case-map covers brands whose collection handle differs from
  handleize(vendor). Keep it in sync with the map in sections/brands.liquid
  consumers — this snippet is the single source of truth.

  @param {string} vendor - The vendor name

  @example
  {% capture brand_url %}{% render 'vendor-collection-url', vendor: product.vendor %}{% endcapture %}
{%- enddoc -%}
{%- liquid
  assign vendor_handle = vendor | handleize
  case vendor
    when 'PRS Guitars'
      assign vendor_handle = 'prs'
    when 'Ernie Ball Music Man'
      assign vendor_handle = 'music-man'
    when 'Zildjian'
      assign vendor_handle = 'zildjan'
    when 'Universal Audio'
      assign vendor_handle = 'apollo'
    when 'Ortega'
      assign vendor_handle = 'ortega-1'
    when 'Vintage'
      assign vendor_handle = 'vintage-guitars'
  endcase
  assign vendor_collection = collections[vendor_handle]
  if vendor_collection.handle == vendor_handle
    echo vendor_collection.url
  else
    echo vendor | url_for_vendor
  endif
-%}
