<meta
  http-equiv="X-UA-Compatible"
  content="IE=edge"
>
<meta
  name="viewport"
  content="width=device-width,initial-scale=1"
>
<meta
  name="view-transition"
  content="same-origin"
>
<meta
  name="theme-color"
  content="#ffffff"
>

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif

  # Resolve share image: prefer page_image, fall back to store logo
  assign og_image = page_image
  if og_image == blank and settings.logo != blank
    assign og_image = settings.logo
  endif
  if og_image != blank
    assign og_image_url = og_image | image_url: width: 1200
    assign og_image_height = 1200 | divided_by: og_image.aspect_ratio | round
  endif
-%}

<meta
  property="og:site_name"
  content="{{ shop.name }}"
>
<meta
  property="og:locale"
  content="{{ request.locale.iso_code | replace: '-', '_' }}"
>
<meta
  property="og:url"
  content="{{ og_url }}"
>
<meta
  property="og:title"
  content="{{ og_title | escape }}"
>
<meta
  property="og:type"
  content="{{ og_type }}"
>
<meta
  property="og:description"
  content="{{ og_description | escape }}"
>

{%- if request.page_type == 'article' -%}
  <meta
    property="article:published_time"
    content="{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}"
  >
  <meta
    property="article:modified_time"
    content="{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S%z' }}"
  >
  {%- if article.author != blank -%}
    <meta
      property="article:author"
      content="{{ article.author | escape }}"
    >
  {%- endif -%}
  {%- if blog.title != blank -%}
    <meta
      property="article:section"
      content="{{ blog.title | escape }}"
    >
  {%- endif -%}
  {%- for tag in article.tags -%}
    <meta
      property="article:tag"
      content="{{ tag | escape }}"
    >
  {%- endfor -%}
{%- endif -%}

{%- if og_image -%}
  <meta
    property="og:image"
    content="https:{{ og_image_url }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ og_image_url }}"
  >
  <meta
    property="og:image:width"
    content="1200"
  >
  <meta
    property="og:image:height"
    content="{{ og_image_height }}"
  >
  <meta
    property="og:image:alt"
    content="{{ og_image.alt | default: og_title | escape }}"
  >
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta
    property="og:price:currency"
    content="{{ cart.currency.iso_code }}"
  >
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta
    name="twitter:site"
    content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}"
  >
{%- endif -%}
<meta
  name="twitter:card"
  content="summary_large_image"
>
<meta
  name="twitter:title"
  content="{{ og_title | escape }}"
>
<meta
  name="twitter:description"
  content="{{ og_description | escape }}"
>
{%- if og_image -%}
  <meta
    name="twitter:image"
    content="https:{{ og_image_url }}"
  >
  <meta
    name="twitter:image:alt"
    content="{{ og_image.alt | default: og_title | escape }}"
  >
{%- endif -%}

<title>
  {{ page_title }}
  {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
  {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
  {%- comment -%} The homepage title is fully authored in Preferences (ends
    with "| MUG") — appending the shop name doubled the branding and pushed
    the title to 94 chars. {%- endcomment -%}
  {%- unless page_title contains shop.name or request.page_type == 'index' %} &ndash; {{ shop.name }}{% endunless -%}
</title>

{%- if current_tags -%}
  <meta name="robots" content="noindex, follow">
{%- endif -%}
<link
  rel="canonical"
  href="{{ canonical_url }}"
>

{%- assign meta_description = page_description | default: shop.description -%}
{% if meta_description %}
  {%- comment -%} Products fall back to a 320-char excerpt of the product
    body — cut it at Google's ~160-char display limit. Collections and pages
    carry hand-written descriptions already inside the limit. {%- endcomment -%}
  {%- if request.page_type == 'product' -%}
    {%- assign meta_description = meta_description | truncate: 158 -%}
  {%- endif -%}
  <meta
    name="description"
    content="{{ meta_description | escape }}"
  >
{% endif %}
