
{%- doc -%}
  Renders product badges for the product card.

  @param {object} product - The product object.
  @param {object} settings - The theme settings object.

  @example
  {% render 'product-card-badges', product: product, settings: settings %}
{%- enddoc -%}

{%- comment %} ── Nyheter: keep tag-based logic intact ── {%- endcomment -%}
{%- assign is_nyhet = false -%}
{%- assign now_seconds = 'now' | date: '%s' | plus: 0 -%}
{%- assign published_seconds = product.published_at | date: '%s' | plus: 0 -%}
{%- assign age_days = now_seconds | minus: published_seconds | divided_by: 86400 -%}
{%- for tag in product.tags -%}
  {%- if tag contains 'Nyheter:' or tag == 'nyhet' or tag == 'new' or tag == 'new-in' -%}
    {%- if age_days <= 60 -%}
      {%- assign is_nyhet = true -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- comment %} ── Status: read from metafield, support list and single-value types ── {%- endcomment -%}
{%- assign status_meta = product.metafields.custom.status -%}
{%- assign status_list = '' -%}
{%- if status_meta != blank -%}
  {%- if status_meta.type contains 'list' -%}
    {%- assign status_list = status_meta.value -%}
  {%- else -%}
    {%- assign status_list = status_meta.value | split: ',' -%}
  {%- endif -%}
{%- endif -%}
{%- assign has_status = false -%}
{%- if status_list != blank -%}
  {%- assign has_status = true -%}
{%- endif -%}

<div
  class="product-badges product-badges--{{ settings.badge_position }}"
  style="
    --badge-border-radius: {{ settings.badge_corner_radius }}px;
    --badge-font-family: var(--font-{{ settings.badge_font_family }}--family);
    --badge-font-weight: var(--font-{{ settings.badge_font_family }}--weight);
    --badge-text-transform: {{ settings.badge_text_transform }};
  "
>
  {%- comment %} ── One badge at a time, in priority order ── {%- endcomment -%}
  {%- if status_list contains 'Begagnad' -%}
    <div class="product-badges__badge product-badges__badge--rectangle color-scheme-status color-scheme-status--begagnad">
      Begagnad
    </div>
  {%- elsif status_list contains 'B-stock' -%}
    <div class="product-badges__badge product-badges__badge--rectangle color-scheme-status color-scheme-status--b-stock">
      B-stock
    </div>
  {%- elsif is_nyhet -%}
    <div class="product-badges__badge product-badges__badge--rectangle color-scheme-nyhet">
      Nyhet
    </div>
  {%- elsif product.available == false -%}
    <div class="product-badges__badge product-badges__badge--rectangle color-{{ settings.badge_sold_out_color_scheme }}">
      {{- 'content.product_badge_sold_out' | t -}}
    </div>
  {%- elsif product.compare_at_price > product.price and product.available -%}
    <div class="product-badges__badge product-badges__badge--rectangle color-{{ settings.badge_sale_color_scheme }} color-scheme-sale">
      {{- 'content.product_badge_sale' | t -}}
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .product-badges {
    --badge-inset: max(var(--padding-xs), calc((var(--border-radius) + var(--padding-xs)) * (1 - cos(45deg))));
    position: absolute;
    z-index: var(--layer-flat);
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 4px;
  }

  .product-badges--bottom-left {
    bottom: calc(var(--badge-inset) + var(--padding-block-start));
    left: calc(var(--badge-inset) + var(--padding-inline-start));
  }

  .product-badges--top-left {
    top: calc(var(--badge-inset) + var(--padding-block-start));
    left: calc(var(--badge-inset) + var(--padding-inline-start));
  }

  .product-badges--top-right {
    top: calc(var(--badge-inset) + var(--padding-block-start));
    right: calc(var(--badge-inset) + var(--padding-inline-start));
  }

  .product-badges__badge {
    --badge-font-size: var(--font-size--xs);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--color-foreground);
    background: var(--color-background);
    font-size: var(--badge-font-size);
    font-family: var(--badge-font-family);
    font-weight: var(--badge-font-weight);
    text-transform: var(--badge-text-transform);
    border-radius: 0px;
    letter-spacing: 1px !important;
  }

  .product-badges__badge--rectangle {
    padding-block: 0.45em 0.4em;
    padding-inline: 0.75em;
    text-transform: uppercase;
  }

  /* Status metafield badges (default) */
  .product-badges__badge.color-scheme-status {
    background: #fff;
    color: #000;
    font-size: 12px!important;
    letter-spacing: 1px;
  }

  /* B-stock status override */
  .product-badges__badge.color-scheme-status--b-stock {
    color: red;
  }

  /* Rea/Sale badge */
  .product-badges__badge.color-scheme-sale {
    background: #fff;
    color: red;
    font-size: 12px!important;
    letter-spacing: 1px;
  }

  /* Nyhet badge */
  .product-badges__badge.color-scheme-nyhet {
    background: #fff;
    color: #000;
    font-size: 12px!important;
    letter-spacing: 1px;
  }
{% endstylesheet %}
