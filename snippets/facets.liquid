{%- if results.filters.size > 0 -%}
  <form id="FacetFiltersForm" class="facets" style="display:inline-block; margin-left:10px;">
    {% for filter in results.filters %}
      {% for value in filter.values %}

        {%- if value.label == 'Finns i butik' or value.param_name contains 'inventory.butik' -%}

          {%- comment -%} Collapsible header with toggle switch {%- endcomment -%}
          <details class="facets__disclosure" open>
            <summary class="facets__summary">
              <span>{{ filter.label }}</span>
            </summary>
            <div class="facets__disclosure-body">
              <label class="facet-toggle" style="display:flex; align-items:center; gap:10px; margin-right:16px; cursor:pointer;">
                <span class="facet-toggle__track {% if value.active %}facet-toggle__track--on{% endif %}">
                  <input
                    type="checkbox"
                    name="{{ value.param_name }}"
                    value="{{ value.value }}"
                    {% if value.active %}checked{% endif %}
                    onchange="this.form.submit()"
                    style="position:absolute; opacity:0; width:0; height:0;"
                  >
                  <span class="facet-toggle__thumb"></span>
                </span>
                <span>{{ value.label }}</span>
              </label>
            </div>
          </details>

        {%- else -%}

          <label style="margin-right:10px;">
            <input
              type="checkbox"
              name="{{ value.param_name }}"
              value="{{ value.value }}"
              {% if value.active %}checked{% endif %}
              onchange="this.form.submit()"
            >
            {{ value.label }}
          </label>

        {%- endif -%}

      {% endfor %}
    {% endfor %}
  </form>
{%- endif -%}

<style>
  .facet-toggle__track {
    position: relative;
    display: inline-block;
    width: 48px;
    height: 28px;
    background-color: #ccc;
    border-radius: 999px;
    flex-shrink: 0;
    transition: background-color 0.2s ease;
  }
  .facet-toggle__track--on {
    background-color: #2a9d4e;
  }
  .facet-toggle__thumb {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 22px;
    height: 22px;
    background: #fff;
    border-radius: 50%;
    transition: transform 0.2s ease;
    pointer-events: none;
  }
  .facet-toggle__track--on .facet-toggle__thumb {
    transform: translateX(20px);
  }
</style>
