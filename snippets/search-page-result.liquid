{% paginate search.results by 24 %}

  <!-- 🔹 Filter + Sort Bar -->
  <div class="filter-sort-bar">
    
    <!-- Filter by collection tags -->
    <form method="get" action="/search" class="filter-box">
      <input type="hidden" name="q" value="{{ search.terms }}">
      <input type="hidden" name="type" value="product">

      <label for="filter">Filter:</label>
      <select id="filter" name="constraint" onchange="this.form.submit()">
        <option value="">All Products</option>
        {% for tag in collection.all_tags %}
          <option value="{{ tag | handleize }}" 
            {% if current_tags contains tag %}selected{% endif %}>
            {{ tag }}
          </option>
        {% endfor %}
      </select>
    </form>

    <!-- Sort -->
    <form method="get" action="/search" class="sort-box">
      <input type="hidden" name="q" value="{{ search.terms }}">
      <input type="hidden" name="type" value="product">

      <label for="sort-by">Sort by:</label>
      <select id="sort-by" name="sort_by" onchange="this.form.submit()">
        <option value="relevance" {% if search.sort_by == "relevance" %}selected{% endif %}>Relevance</option>
        <option value="price-ascending" {% if search.sort_by == "price-ascending" %}selected{% endif %}>Price, Low to High</option>
        <option value="price-descending" {% if search.sort_by == "price-descending" %}selected{% endif %}>Price, High to Low</option>
        <option value="created-descending" {% if search.sort_by == "created-descending" %}selected{% endif %}>Newest</option>
        <option value="created-ascending" {% if search.sort_by == "created-ascending" %}selected{% endif %}>Oldest</option>
      </select>
    </form>
  </div>

{% comment %}
<div
    class="facets-toggle {% if block_settings.filter_style == 'horizontal' and block_settings.inherit_color_scheme == false %} color-{{ block_settings.color_scheme }}{% endif %}"
    style="
      --facets-inner-padding-block: {{ block_settings.padding-block-start }}px {{ block_settings.padding-block-end }}px; --facets-inner-padding-inline: var(--padding-lg);
      {{ facets_margin_style }}
    "
  >
 
  <div class="facets-toggle__wrapper">
    <button
      class="button facets-toggle__button button-unstyled button-unstyled--with-icon"
      on:click="#filters-drawer/showDialog"
      type="button"
    >
<!-- PNG Icon -->
<div class="facets-toggle__icon">
  <span class="svg-wrapper">
    <img 
      src="{{ 'Icon - Filter.png' | asset_url }}" 
      alt="Filter Icon" 
      class="icon-filter"
      width="20"
      height="20"
      style="display: block; object-fit: contain;"
    >
  </span>
</div>


      <!-- Filter Label + Active Count -->
      <div class="facets-toggle__info">
        <h4 class="facets-toggle__label">Filtrera</h4>

        {% assign total_active_values = search.results  %}
        {% if total_active_values > 0 %}
          <div 
            id="filter-count-bubble-toggle"
            class="filter-count-bubble"
            aria-label="({{ 'accessibility.filter_count' | t: count: total_active_values }})"
          >
            <span
              ref="cartBubbleText"
              class="filter-count-bubble__text"
              aria-hidden="true"
            >
              ({{ total_active_values }})
            </span>
          </div>
        {% endif %}
      </div>
    </button>
  </div>
  </div>
{% endcomment %}
  

  <!-- 🔹 Product Grid -->
  <div class="product-grid search-page">
    {% for item in search.results %}
      {% if item.object_type == 'product' %}
        <div class="product-card">
          <div class="product-image">
  <!-- 🔹 BADGES -->
  <div class="badge-wrapper">
    {% if item.compare_at_price > item.price %}
      <span class="badge sale-badge">SALE</span>
    {% endif %}
    {% unless item.available %}
      <span class="badge outofstock-badge">OUT OF STOCK</span>
    {% endunless %}
    {% if item.tags contains 'new' %}
      <span class="badge newin-badge">NEW IN</span>
    {% endif %}
    {% if item.tags contains 'vintage' %}
      <span class="badge vintage-badge">VINTAGE</span>
    {% endif %}
  </div>

  <!-- 🔹 IMAGE -->
  <a href="{{ item.url }}" class="search-result__image-wrapper">
    <div class="product-media__lqip" style="background-image: url('{{ item.featured_image | image_url: width: 100 }}')"></div>
    {{ item.featured_image | image_url: width: 600 | image_tag: alt: item.featured_image.alt | default: item.title, class: 'product-media__image--lqip', loading: 'lazy', decoding: 'async', widths: '200, 400, 600', sizes: '(min-width: 750px) 25vw, 50vw' }}
  </a>
</div>

          <div class="product-info">
            {%- assign brand = item.vendor | default: item.product.vendor -%}
{% if brand %}
  <div class="product-vendor">{{ brand }}</div>
{% endif %}
<h2 class="product-title"><a href="{{ item.url }}">{{ item.title }}</a></h2>

            <p class="product-price">
  {% if item.compare_at_price > item.price %}
    <!-- Old Price (crossed out) -->
    <span class="old-price">{{ item.compare_at_price | money }}</span>
    <!-- New Discounted Price -->
    <span class="new-price">{{ item.price | money }}</span>
  {% else %}
    <!-- Regular Current Price -->
    <span class="current-price">{{ item.price | money }}</span>
  {% endif %}
</p>

          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

{% if paginate.pages > 1 %}
  <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
    <ul class="pagination__list" role="list">
      
      {%- if paginate.previous -%}
        <li class="pagination__item pagination__item--prev">
          <a href="{{ paginate.previous.url | escape }}#ResultsList"
            rel="prev"
            aria-label="{{ 'general.pagination.previous' | t }}">
            <span class="pagination__arrow">◄</span> Föregående
          </a>
        </li>
      {%- endif -%}

      {%- for part in paginate.parts -%}
        {% if part.is_link %}
          <li class="pagination__item">
            <a href="{{ part.url | escape }}#ResultsList"
              aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
              {{ part.title }}
            </a>
          </li>
        {% elsif part.title == paginate.current_page %}
          <li class="pagination__item pagination__item--current" aria-current="page">
            {{ part.title }}
          </li>
        {% else %}
          <li class="pagination__item pagination__item--ellipsis">
            <span class="pagination__ellipsis">{{ part.title }}</span>
          </li>
        {% endif %}
      {%- endfor -%}

      {%- if paginate.next -%}
        <li class="pagination__item pagination__item--next">
          <a href="{{ paginate.next.url | escape }}#ResultsList"
            rel="next"
            aria-label="{{ 'general.pagination.next' | t }}">
            Nästa <span class="pagination__arrow">►</span>
          </a>
        </li>
      {%- endif -%}

    </ul>
  </nav>
{% endif %}


{% endpaginate %}

<style>
  /* Desktop: 4 columns + desktop border frame */
  @media only screen and (min-width: 769px) {
    .product-grid.search-page {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0;
      --grid-border-desktop: #ddd;      /* adjust desktop border color here */
      border: 1px solid var(--grid-border-desktop);
    }

    .product-card {
      border: 0;
      border-left: 1px solid var(--grid-border-desktop);
    }

    .product-card:last-child {
      border-right: 1px solid var(--grid-border-desktop);
    }

    /* First row (items 1..4) – no top border */
    .product-card:nth-child(-n + 4) {
      border-top: 0;
    }

    /* First column (1,5,9,...) – no left border */
    .product-card:nth-child(4n + 1) {
      border-left: 0;
    }
  }

  /* Mobile: 2 columns + dedicated mobile border frame */
  @media only screen and (max-width: 768px) {
    .product-grid.search-page {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0;
      --grid-border-mobile: #cfcfcf;    /* adjust mobile border color here */
      {% comment %} border: 1px solid var(--grid-border-mobile); {% endcomment %}
    }

    .product-card {
      border: 0;
      border-left: 1px solid var(--grid-border-mobile);
      /*border-top: 1px solid var(--grid-border-mobile);*/
    }

    /* First row (items 1..2) – no top border */
    .product-card:nth-child(-n + 2) {
      {% comment %} border-top: 0; {% endcomment %}
    }

    /* First column (1,3,5,...) – no left border */
    {% comment %} .product-card:nth-child(2n + 1) {
      border-left: 0;
    } {% endcomment %}
  }


  /* =========================
     Product grid (desktop)
     ========================= */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr); /* 4 per row */
    gap: 0;
    margin: 20px auto;
    max-width: 1200px; /* optional */
  }

  .product-card {
    {% comment %} border: 1px solid #ddd; {% endcomment %}
    text-align: left;
    background: #fff;
  }

  .search-page .product-image {
    border-bottom: 1px solid #ddd;
    background: #f5f5f5;
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;  /* 🔹 Keeps it always square */
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .product-card img {
    width: 100%;
    height: 100%;
  }

  .product-info {
    padding: 15px;
  }

  .product-title {
    padding-left: 0;
    font-weight: normal;
    font-size: 15px;
    margin: 4px 0 4px;
    line-height: 24px;
  }

  .product-title:hover {
    text-underline: none !important;
  }

  .product-vendor {
    margin-top: 0px;
    margin-bottom: 4px;
    font-size: 13px;
    font-family: "Inter Variable", sans-serif !important;
    font-feature-settings: 'ss07' 1;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: black;
  }

  .product-price {
    font-size: 14px;
  }

  .product-price .current-price {
    color: black;
    font-weight: normal;
    font-size: 14px;
    font-family: "Inter Variable", sans-serif !important;
    font-feature-settings: 'ss07' 1;
  }
  .product-price .old-price {
  color: black;                /* gray tone for contrast */
  font-size: 14px;            /* match your current price size */
  text-decoration: line-through; /* 🔹 creates the strike-through line */
  margin-right: 6px;  
  font-family: "Inter Variable", sans-serif !important;
  font-feature-settings: 'ss07' 1;        /* small space before the new price */
}
.product-price .new-price {
  color: #d12f2f; /* red tone for sale */
  font-size: 14px;
    font-family: "Inter Variable", sans-serif !important;
  font-feature-settings: 'ss07' 1; 
}


  .product-grid img,
  .product-media-container img,
  .product-information__media img,
  .resource-card__media img,
  .cart-items__media img {
    filter: none !important;
  }

  /* =========================
     Filter + Sort bar
     ========================= */
  .filter-sort-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 20px 0;
    width: 100%;
    max-width: 1200px; /* optional */
  }

  .filter-box,
  .sort-box {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .filter-sort-bar label {
    font-weight: bold;
  }

  .filter-sort-bar select {
    padding: 6px 10px;

    border-radius: 4px;
    background: #fff;
  }

  /* =========================
     Pagination
     ========================= */
  /* Pagination styles */
.pagination {
  margin-top: 0 !important;
  text-align: center;
}

.pagination__list {
  display: inline-flex;
  gap: 8px;
  align-items: center;
  list-style: none;
  padding: 0;
}

.pagination__item a {
  text-decoration: none;
  color: #000;
}

.pagination__item--current {
  font-weight: 600;
  background: #000;
  color: #fff;
}

.pagination__item--prev a,
.pagination__item--next a {
  font-weight: 500;
}

.pagination__arrow {
  font-size: 12px;
}

.pagination__ellipsis {
  color: #000000;
}


  /* =========================
     Mobile (≤ 768px)
     ========================= */
  @media (max-width: 768px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
      width: 100%;
    }

    .product-card {
      display: flex;
      flex-direction: column;
      height: 100%;
      width: 100%;
      box-sizing: border-box;
    }

    .product-image {
      width: 100%;
      height: 180px;          /* fixed height for all images */
      overflow: hidden;
      flex-shrink: 0;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    /* Override desktop padding so object-fit fills properly */
    .product-image img {
            border-bottom: 1px solid black !important;
      width: 100%;
      height: 100%;
      padding: 0;
      object-fit: cover;
      object-position: center;
      display: block;
    }

    .product-title {
      font-size: 14px;
      margin: 6px 0 4px;
      line-height: 1.3em;
      display: -webkit-box;
      -webkit-line-clamp: 2;     /* max 2 lines */
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .product-price {
      font-size: 13px;
      font-weight: bold;
      margin-top: auto;
    }

    .filter-sort-bar {
      flex-wrap: nowrap;
      gap: 6px;
      margin: 10px 0;
      justify-content: space-between;
    }

    .filter-box,
    .sort-box {
      flex: 1 1 auto;
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .filter-sort-bar label {
      font-size: 12px;
      font-weight: 600;
      white-space: nowrap;
    }

    .filter-sort-bar select {
      font-size: 12px;
      padding: 3px 5px;
      min-width: 90px;
      max-width: 110px;
    }

    .custom-pagination ul {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 6px;
    }

    .custom-pagination li {
      padding: 4px 8px;
      font-size: 10px;
      flex-shrink: 0;
    }
  }

  /* =========================
   Product badges
   ========================= */
.product-image {
  position: relative;
  overflow: hidden;
}

.badge-wrapper {
  position: absolute;
  top: 10px;
  left: 10px;
  display: flex;
  flex-direction: row;
  gap: 4px;
  z-index: 2;
}
.badge{
padding-left:10px;
padding-right:10px;
padding-bottom:4px;
padding-top:4px;
margin-right:5px;
}



/* --- Badge colors --- */
.sale-badge {
  color: #d12f2f; /* red */
}

.outofstock-badge {
  color: black; /* gray */
}

.newin-badge {
  color: #007bff; /* blue */
}

.vintage-badge {
  color: #b5651d; /* brown/gold */
}

/* Optional hover effect */
.badge:hover {
  opacity: 0.85;
}

</style>