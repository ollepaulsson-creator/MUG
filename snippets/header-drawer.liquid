<script>
  (function () {
    /**
     * Reads the header's current bottom edge and writes --header-bottom
     * directly onto the .menu-drawer element as an inline style.
     * Inline style specificity overrides the inherited value set on <body>
     * by header.js, so the drawer always sees the freshest value.
     */
    function syncDrawerTop() {
      var header = document.getElementById('header-component');
      var drawer = document.querySelector('[data-header-drawer]');
      if (!header || !drawer) return;
      var bottom = Math.max(0, header.getBoundingClientRect().bottom);
      drawer.style.setProperty('--header-bottom', bottom + 'px');
    }

    var raf;
    function scheduleSync() {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(syncDrawerTop);
    }

    function init() {
      var header = document.getElementById('header-component');
      if (header && 'ResizeObserver' in window) {
        new ResizeObserver(scheduleSync).observe(header);
      }
      window.addEventListener('resize', scheduleSync, { passive: true });
      syncDrawerTop();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    /**
     * Replay the settle animation on the bg-settle element when the user
     * navigates back from a submenu. The bg-settle is the drawer's preceding
     * sibling (inside the same <details>), so walk up to the parent and find it.
     * The drawer content (nav, footer, etc.) is never touched by the animation.
     */
    document.addEventListener('click', function (e) {
      if (!e.target.closest('.menu-drawer__back-button')) return;
      var drawer = document.querySelector('[data-header-drawer]');
      if (!drawer) return;
      var bg = drawer.parentElement && drawer.parentElement.querySelector('.menu-drawer__bg-settle');
      if (!bg) return;
      bg.style.animation = 'none';
      void bg.offsetWidth; // force reflow so the browser commits "none"
      bg.style.animation = '';
    });
  })();
</script>

{% stylesheet %}
  .header__icon--menu {
    position: initial;
  }

  @media screen and (min-width: 750px) {
    .header--desktop header-menu + .header__drawer header-drawer {
      display: none;
    }
  }

  .menu-drawer-container .header__icon--summary {
    color: #000;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--padding-lg);
    min-width: 44px;
    min-height: 44px;
  }

  .header__icon--summary .header-drawer-icon {
    margin: auto;
    width: var(--icon-size-xs);
    height: var(--icon-size-xs);
  }

  .header__drawer {
    display: flex;
    min-height: 60px;
    align-items: center;

    @media screen and (min-width: 750px) {
      min-height: 0;
    }
  }

  .header--compact .header__drawer {
    min-height: var(--minimum-touch-target);
  }

  .menu-drawer__navigation {
    padding: 0;

    @media screen and (min-width: 750px) {
    margin-top: var(--drawer-header-desktop-top);
    }
  }

  /* Hamburger ↔ ✕ cross-fade animation */
  .header__icon--summary {
    position: relative;
  }

  .header__icon--summary .header-drawer-icon {
    transition: opacity 0.2s cubic-bezier(0.2, 0, 0, 1),
                transform 0.2s cubic-bezier(0.2, 0, 0, 1),
                filter 0.2s cubic-bezier(0.2, 0, 0, 1);
  }

  /* Close icon: hidden by default, positioned over the hamburger */
  .header__icon--summary .header-drawer-icon--close {
    position: absolute;
    inset: 0;
    margin: auto;
    display: flex !important;
    opacity: 0;
    transform: scale(0.25);
    filter: blur(4px);
  }

  /* Hamburger icon: visible by default — slightly larger on mobile */
  .header__icon--summary .header-drawer-icon--open {
    display: flex !important;
    opacity: 1;
    transform: scale(1.2);
    filter: blur(0px);
  }

  /* When menu is open on mobile: swap icons */
  details[open] .header__icon--menu .header-drawer-icon--open {
    opacity: 0;
    transform: scale(0.25);
    filter: blur(4px);
  }

  details[open] .header__icon--menu .header-drawer-icon--close {
    opacity: 1;
    transform: scale(1);
    filter: blur(0px);
  }

  /* On desktop: always show hamburger at normal scale, never ✕ */
  @media screen and (min-width: 750px) {
    .header__icon--summary .header-drawer-icon--open {
      transform: scale(1);
    }

    details[open] .header__icon--menu .header-drawer-icon--open {
      opacity: 1;
      transform: scale(1);
      filter: blur(0px);
    }

    details[open] .header__icon--menu .header-drawer-icon--close {
      opacity: 0;
      transform: scale(0.25);
      filter: blur(4px);
    }
  }

  .menu-drawer {
    position: fixed;
    clip-path: inset(0 0 100% 0);
    visibility: hidden;
    height: calc(100dvh - var(--header-bottom, 60px));
    width: 100vw;
    max-width: 100vw;
    z-index: var(--layer-menu-drawer);
    left: 0;
    top: var(--header-bottom, 60px);
    padding: 0;
    background-color: var(--color-background);
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: none;
    &::-webkit-scrollbar { display: none; }
    display: flex;
    border-top: 1px solid #DCDCDC;
    border-right: var(--style-border-drawer);
    box-shadow: none;
    flex-direction: column;

    @media screen and (min-width: 750px) {
      width: 25rem;
    }

    .header__drawer--desktop & {
      height: 100vh;
      top: 0;
    }
  }

  .menu-drawer__backdrop {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100dvh;
    backdrop-filter: brightness(0.75);
    z-index: var(--layer-heightened);
    opacity: 0;
    transition: opacity var(--drawer-animation-speed) ease;

    .menu-open & {
      opacity: 1;
    }
  }

  @keyframes slide-down-fade-in {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Drawer background settles from 30% oversized to actual size */
  @keyframes menu-drawer-settle {
    from { transform: scaleY(1.3); }
    to   { transform: scaleY(1);   }
  }

  .menu-drawer {
    transition: clip-path 0.3s ease-out, visibility 0.3s ease-out;
  }

  /* Reset animation when drawer is closed so it replays on every open */
  .menu-drawer .menu-drawer__list-item {
    animation: none;
  }

  /* Stagger slide-down + fade-in for menu items when the drawer opens */
  .menu-open > .menu-drawer .menu-drawer__list-item {
    --index: var(--menu-drawer-animation-index, 0);
    animation: slide-down-fade-in 0.35s ease-out calc(var(--index) * 0.05s) backwards;
  }

  .menu-drawer__submenu {
    transition: transform var(--drawer-animation-speed) ease, visibility var(--drawer-animation-speed) ease;
  }

  .menu-open > .menu-drawer {
    clip-path: inset(0 0 0% 0);
    visibility: visible;
    display: flex;
    flex-direction: column;
    background-color: transparent; /* bg-settle sibling provides the white background */
  }

  /*
   * The settle animation lives on .menu-drawer__bg-settle — a sibling of the
   * drawer, not a parent/ancestor. This keeps the drawer's content (nav, footer,
   * etc.) completely untouched by the transform so no elements shift or scale.
   * The bg-settle is position:fixed so it lines up exactly behind the drawer.
   */
  .menu-drawer__bg-settle {
    display: none;
    position: fixed;
    top: var(--header-bottom, 60px);
    left: 0;
    width: 100vw;
    height: calc(100dvh - var(--header-bottom, 60px));
    background-color: var(--color-background);
    z-index: calc(var(--layer-menu-drawer) - 1);
    pointer-events: none;
    transform-origin: top center;
  }

  .menu-open > .menu-drawer__bg-settle {
    display: block;
    animation: menu-drawer-settle 0.8s ease-in-out both;
  }

  /* When a submenu is active, make it visible — its transform stays at translateX(100%).
     The parent UL slides to translateX(-100%), which nets to visual position 0 for the submenu. */
  .menu-open > .menu-drawer__submenu:not(.menu-drawer__menu--childlist) {
    visibility: visible;
  }

  .menu-drawer__inner-container {
    position: relative;
    height: 100%;
  }

  .menu-drawer__navigation-container {
    display: flex;
    flex-direction: column;
